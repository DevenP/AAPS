<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
	<AssemblyInformationalVersion>1.0.0.1-beta</AssemblyInformationalVersion>
    <!-- CS8669: nullable annotations in auto-generated .razor.g.cs files (noise, not our code) -->
    <NoWarn>$(NoWarn);CS8669</NoWarn>
    <!-- Fail the build if a MudBlazor/Razor API is silently ignored (e.g. a removed
         component template or parameter after a package upgrade), instead of degrading at runtime.
         RZ10012 = unexpected markup element; MUD0001/MUD0002 = illegal component attribute. -->
    <WarningsAsErrors>$(WarningsAsErrors);RZ10012;MUD0001;MUD0002</WarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\AAPS.Application\AAPS.Application.csproj" />
    <ProjectReference Include="..\AAPS.Infrastructure\AAPS.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.9">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="MudBlazor" Version="9.7.0" />
    <PackageReference Include="Serilog.AspNetCore" Version="10.0.0" />
    <PackageReference Include="Serilog.Sinks.MSSqlServer" Version="10.0.0" />
    <PackageReference Include="Serilog.Sinks.Seq" Version="9.1.0" />
  </ItemGroup>

</Project>
