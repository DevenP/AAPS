@using AAPS.Application.Abstractions.Services
@using System.Text
@inject IImportService ImportService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<div style="height:calc(100vh - 200px); display:flex; flex-direction:column; overflow:hidden;">

    @* ── Step indicator ── *@
    <div class="d-flex align-center gap-4 mb-4">
        <StepBadge Number="1" Label="Upload" Active="@(_step >= 1)" Done="@(_step > 1)" />
        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Class="mud-text-secondary" />
        <StepBadge Number="2" Label="Preview" Active="@(_step >= 2)" Done="@(_step > 2)" />
        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Class="mud-text-secondary" />
        <StepBadge Number="3" Label="Done" Active="@(_step >= 3)" Done="@(_step >= 3)" />
    </div>

    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-4">@Description</MudText>

    @* ── STEP 1: Upload ── *@
    @if (_step == 1)
    {
        <div class="import-drop-zone" style="@(_isDragging ? "border-color: var(--mud-palette-primary-darken); background-color: var(--mud-palette-action-default-hover);" : "")">
            @if (_loading)
            {
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" Class="mb-3" />
                <MudText Typo="Typo.body1">Processing file...</MudText>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Style="font-size:3.5rem; pointer-events:none;" Color="Color.Primary" Class="mb-2" />
                <MudText Typo="Typo.h6" Class="mb-1" Style="pointer-events:none;">Drop your Excel file here</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="pointer-events:none;">or click to browse (.xlsx)</MudText>
            }
            <InputFile accept=".xlsx"
                       OnChange="OnFileInputChanged"
                       disabled="@_loading"
                       @ondragenter="@(() => _isDragging = true)"
                       @ondragleave="@(() => _isDragging = false)"
                       @ondrop="@(() => _isDragging = false)"
                       style="position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%;" />
        </div>

        @if (_parseError != null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-4" Style="white-space:pre-line">@_parseError</MudAlert>
        }
    }

    @* ── STEP 2: Preview ── *@
    @if (_step == 2 && _preview != null)
    {
        <div class="d-flex align-center justify-space-between mb-3" style="flex-shrink:0;">
            <div class="d-flex align-center gap-3">
                <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle">
                    @_preview.ValidRows.Count valid
                </MudChip>
                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.Warning">
                    @_preview.SkippedRows.Count skipped
                </MudChip>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    @_preview.FileName
                </MudText>
                @if (ImportType == ImportType.Payments && _preview.ValidRows.Count > 0)
                {
                    var voucher = _preview.ValidRows[0].PreviewColumns.GetValueOrDefault("Voucher");
                    if (!string.IsNullOrWhiteSpace(voucher))
                    {
                        <MudChip T="string" Color="Color.Info" Size="Size.Small" Icon="@Icons.Material.Filled.Receipt">
                            Voucher: @voucher
                        </MudChip>
                    }
                }
            </div>
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Reset" Disabled="_loading">
                    Cancel
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="Confirm"
                           Disabled="_loading || _preview.ValidRows.Count == 0">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Importing...</span>
                    }
                    else
                    {
                        <span>Confirm Import (@_preview.ValidRows.Count rows)</span>
                    }
                </MudButton>
            </div>
        </div>

        @* Preview tabs: Valid / Skipped *@
        <MudTabs Elevation="0" Rounded="false" @bind-ActivePanelIndex="_previewTab" Style="flex:1; min-height:0; display:flex; flex-direction:column;">
            <MudTabPanel Text="@($"Valid Rows ({_preview.ValidRows.Count})")" Style="flex:1; min-height:0;">
                @if (_preview.ValidRows.Count > PreviewLimit)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                        Preview limited to the first @PreviewLimit rows. All @_preview.ValidRows.Count rows will be imported.
                    </MudAlert>
                }
                <div style="flex:1; min-height:0; overflow:auto; height:calc(100vh - 380px);">
                    <MudTable Items="@_preview.ValidRows.Take(PreviewLimit).ToList()"
                              Dense="true"
                              Hover="true"
                              Striped="true"
                              FixedHeader="true"
                              Height="100%"
                              Elevation="1">
                        <HeaderContent>
                            @foreach (var col in PreviewColumns)
                            {
                                <MudTh>@col</MudTh>
                            }
                        </HeaderContent>
                        <RowTemplate>
                            @foreach (var col in PreviewColumns)
                            {
                                <MudTd>
                                    <MudText Typo="Typo.body2">
                                        @(context.PreviewColumns.TryGetValue(col, out var v) ? v : "")
                                    </MudText>
                                </MudTd>
                            }
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudAlert Severity="Severity.Info">No valid rows found.</MudAlert>
                        </NoRecordsContent>
                    </MudTable>
                </div>
            </MudTabPanel>

            <MudTabPanel Text="@($"Skipped Rows ({_preview.SkippedRows.Count})")" Style="flex:1; min-height:0;">
                <div class="d-flex align-center justify-space-between mb-2">
                    @if (_preview.SkippedRows.Count > PreviewLimit)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Style="flex:1; margin-right:8px;">
                            Preview limited to the first @PreviewLimit skipped rows. Export to see all @_preview.SkippedRows.Count.
                        </MudAlert>
                    }
                    else
                    {
                        <span></span>
                    }
                    <MudButton StartIcon="@Icons.Material.Filled.Download"
                               Variant="Variant.Outlined"
                               Color="Color.Warning"
                               Size="Size.Small"
                               Disabled="@(_preview.SkippedRows.Count == 0)"
                               OnClick="ExportSkipped">
                        Export Skipped
                    </MudButton>
                </div>
                <div style="flex:1; min-height:0; overflow:auto; height:calc(100vh - 415px);">
                    <MudTable Items="@_preview.SkippedRows.Take(PreviewLimit).ToList()"
                              Dense="true"
                              Hover="true"
                              Striped="true"
                              FixedHeader="true"
                              Height="100%"
                              Elevation="1">
                        <HeaderContent>
                            <MudTh>Skip Reason</MudTh>
                            @foreach (var col in PreviewColumns)
                            {
                                <MudTh>@col</MudTh>
                            }
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.SkipReason</MudChip>
                            </MudTd>
                            @foreach (var col in PreviewColumns)
                            {
                                <MudTd>
                                    <MudText Typo="Typo.body2">
                                        @(context.PreviewColumns.TryGetValue(col, out var v) ? v : "")
                                    </MudText>
                                </MudTd>
                            }
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudAlert Severity="Severity.Success">No rows were skipped!</MudAlert>
                        </NoRecordsContent>
                    </MudTable>
                </div>
            </MudTabPanel>
        </MudTabs>
    }

    @* ── STEP 3: Done ── *@
    @if (_step == 3 && _result != null)
    {
        <div class="d-flex flex-column align-center justify-center" style="flex:1;">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size:4rem;" Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mb-2">Import Complete</MudText>

            @if (ImportType == ImportType.Payments)
            {
                var voucherNum = _preview?.ValidRows.FirstOrDefault()?.PreviewColumns.GetValueOrDefault("Voucher");
                @if (!string.IsNullOrWhiteSpace(voucherNum))
                {
                    <MudChip T="string" Color="Color.Info" Size="Size.Small" Icon="@Icons.Material.Filled.Receipt" Class="mb-3">
                        Voucher @voucherNum
                    </MudChip>
                }
                <MudText Typo="Typo.body1" Class="mb-1">
                    <b>@_result.Updated</b> Provider Billing records updated with payment info
                </MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                    @_result.Skipped rows had no matching Provider Billing record
                </MudText>
                @if (_result.Updated == 0)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-4">
                        No Provider Billing records were matched. Check that the correct file was uploaded and that sessions have been imported first.
                    </MudAlert>
                }
            }
            else
            {
                <MudText Typo="Typo.body1" Class="mb-1">
                    <b>@_result.Inserted</b> rows inserted successfully
                </MudText>
                @if (_result.Skipped > 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-1">
                        @_result.Skipped rows were skipped (duplicates or missing required fields)
                    </MudText>
                }
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                    File archived to server.
                </MudText>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Reset">
                Import Another File
            </MudButton>
        </div>
    }

</div>

<style>
    .import-drop-zone {
        position: relative;
        border: 2px dashed var(--mud-palette-primary);
        border-radius: 12px;
        padding: 60px 40px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 220px;
        transition: border-color 0.15s, background-color 0.15s;
    }

    .import-drop-zone:hover {
        background-color: var(--mud-palette-action-default-hover);
    }
</style>

@code {
    private const int PreviewLimit = 500;

    [Parameter] public ImportType ImportType { get; set; }
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string[] PreviewColumns { get; set; } = [];
    [Parameter] public EventCallback OnImported { get; set; }

    private int _step = 1;
    private int _previewTab = 0;
    private bool _loading = false;
    private bool _isDragging = false;
    private string? _parseError;
    private ImportPreviewResult? _preview;
    private ImportCommitResult? _result;

    private Task OnFileInputChanged(InputFileChangeEventArgs e) => OnFileSelected(e.File);

    private async Task OnFileSelected(IBrowserFile file)
    {
        _parseError = null;
        _isDragging = false;
        _loading = true;
        StateHasChanged();
        await Task.Yield(); // let the spinner render before heavy parsing starts

        try
        {
            const long maxSize = 50 * 1024 * 1024; // 50MB
            using var stream = file.OpenReadStream(maxSize);
            _preview = await ImportService.ParseAsync(ImportType, file.Name, stream);
            _step = 2;

            // Auto-switch to skipped tab if no valid rows
            _previewTab = _preview.ValidRows.Count == 0 ? 1 : 0;

            if (_preview.ValidRows.Count == 0 && _preview.SkippedRows.Count == 0)
            {
                _parseError = "The file appears to be empty or has no data rows.";
                _step = 1;
            }
        }
        catch (Exception ex)
        {
            _parseError = $"Failed to parse file: {ex.Message}";
            _step = 1;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Confirm()
    {
        if (_preview == null) return;

        _loading = true;
        StateHasChanged();
        await Task.Delay(1); // yield to renderer so spinner appears before heavy work

        try
        {
            _result = await ImportService.CommitAsync(ImportType, _preview);
            await ImportService.ArchiveFileAsync(ImportType, _preview.FileName, _preview.FileBytes);
            _step = 3;
            await OnImported.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void Reset()
    {
        _step = 1;
        _previewTab = 0;
        _preview = null;
        _result = null;
        _parseError = null;
        _loading = false;
    }

    private async Task ExportSkipped()
    {
        if (_preview == null || _preview.SkippedRows.Count == 0) return;

        var sb = new StringBuilder();

        // Header row: Skip Reason + all preview columns
        var headers = new[] { "Skip Reason" }.Concat(PreviewColumns);
        sb.AppendLine(string.Join(",", headers.Select(h => $"\"{h}\"")));

        // Data rows
        foreach (var row in _preview.SkippedRows)
        {
            var values = new[] { row.SkipReason ?? "" }
                .Concat(PreviewColumns.Select(col =>
                    row.PreviewColumns.TryGetValue(col, out var v) ? (v ?? "") : ""))
                .Select(v => $"\"{v?.Replace("\"", "\"\"")}\"");
            sb.AppendLine(string.Join(",", values));
        }

        var fileName = $"skipped_{Path.GetFileNameWithoutExtension(_preview.FileName)}_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv", Encoding.UTF8.GetBytes(sb.ToString()));
    }
}
