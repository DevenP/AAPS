@page "/"
@using AAPS.Application.Abstractions.Services
@inject IDashboardService DashboardService

<PageTitle>Home — AAPS</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Dashboard</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-5">Welcome to the AAPS Portal</MudText>

@* ── Stat Cards ───────────────────────────────────────────── *@
@if (_stats == null)
{
    <MudGrid Spacing="3" Class="mb-6">
        @for (int i = 0; i < 7; i++)
        {
            <MudItem xs="6" sm="4" md="3">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudSkeleton Width="60%" Height="20px" Class="mb-2" />
                    <MudSkeleton Width="40%" Height="36px" />
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudGrid Spacing="3" Class="mb-6">

        @* Urgent first *@
        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="@($"border-left: 4px solid {(_stats.OperationAlerts > 0 ? "var(--mud-palette-error)" : "var(--mud-palette-success)")};")">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Operation Alerts</MudText>
                <div class="d-flex align-center justify-space-between mt-1">
                    <MudText Typo="Typo.h4" Color="@(_stats.OperationAlerts > 0 ? Color.Error : Color.Default)">
                        <b>@_stats.OperationAlerts</b>
                    </MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="@(_stats.OperationAlerts > 0 ? Color.Error : Color.Success)" Style="font-size:2rem;" />
                </div>
                <MudLink Href="/operations" Typo="Typo.caption" Color="Color.Primary">View Operations</MudLink>
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="@($"border-left: 4px solid {(_stats.ExpiringApprovals > 0 ? "var(--mud-palette-error)" : "var(--mud-palette-success)")};")">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Approvals Expiring (30d)</MudText>
                <div class="d-flex align-center justify-space-between mt-1">
                    <MudText Typo="Typo.h4" Color="@(_stats.ExpiringApprovals > 0 ? Color.Error : Color.Default)">
                        <b>@_stats.ExpiringApprovals</b>
                    </MudText>
                    <MudIcon Icon="@Icons.Material.Filled.EventBusy" Color="@(_stats.ExpiringApprovals > 0 ? Color.Error : Color.Success)" Style="font-size:2rem;" />
                </div>
                <MudLink Href="@_expiringApprovalsUrl" Typo="Typo.caption" Color="Color.Primary">View Approvals</MudLink>
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="@($"border-left: 4px solid {(_stats.UnbilledSessions > 0 ? "var(--mud-palette-warning)" : "var(--mud-palette-success)")};")">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Unbilled Sessions</MudText>
                <div class="d-flex align-center justify-space-between mt-1">
                    <div>
                        <MudText Typo="Typo.h4" Color="@(_stats.UnbilledSessions > 0 ? Color.Warning : Color.Default)" Style="line-height:1.1;">
                            <b>@_stats.UnbilledSessions</b>
                        </MudText>
                        @if (_stats.UnbilledSessions > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning">@_stats.UnbilledAmount.ToString("C0")</MudText>
                        }
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Color="@(_stats.UnbilledSessions > 0 ? Color.Warning : Color.Success)" Style="font-size:2rem;" />
                </div>
                <MudLink Href="/billing?col_Billed=null&col_BillingRate=notnull&col_BilledPaidOn=null" Typo="Typo.caption" Color="Color.Primary">View Billing</MudLink>
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="@($"border-left: 4px solid {(_stats.EvalsPendingPayment > 0 ? "var(--mud-palette-warning)" : "var(--mud-palette-success)")};")">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Evals Pending Payment</MudText>
                <div class="d-flex align-center justify-space-between mt-1">
                    <MudText Typo="Typo.h4" Color="@(_stats.EvalsPendingPayment > 0 ? Color.Warning : Color.Default)">
                        <b>@_stats.EvalsPendingPayment</b>
                    </MudText>
                    <MudIcon Icon="@Icons.Material.Filled.PendingActions" Color="@(_stats.EvalsPendingPayment > 0 ? Color.Warning : Color.Success)" Style="font-size:2rem;" />
                </div>
                <MudLink Href="/evaluations?col_BilledDate=notnull&col_BillPaidDate=null" Typo="Typo.caption" Color="Color.Primary">View Evaluations</MudLink>
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="@($"border-left: 4px solid {(_stats.VendorPortalDiscrepancies > 0 ? "var(--mud-palette-error)" : "var(--mud-palette-success)")};")">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Vendor Portal Discrepancies</MudText>
                <div class="d-flex align-center justify-space-between mt-1">
                    <MudText Typo="Typo.h4" Color="@(_stats.VendorPortalDiscrepancies > 0 ? Color.Error : Color.Default)">
                        <b>@_stats.VendorPortalDiscrepancies</b>
                    </MudText>
                    <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Color="@(_stats.VendorPortalDiscrepancies > 0 ? Color.Error : Color.Success)" Style="font-size:2rem;" />
                </div>
                <MudLink Href="/vendorportal?col_MismatchedVendorPortal=true" Typo="Typo.caption" Color="Color.Primary">View Vendor Portal</MudLink>
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="@($"border-left: 4px solid {(_stats.ExpiringLicenses > 0 ? "var(--mud-palette-warning)" : "var(--mud-palette-success)")};")">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Expiring Licenses (60d)</MudText>
                <div class="d-flex align-center justify-space-between mt-1">
                    <MudText Typo="Typo.h4" Color="@(_stats.ExpiringLicenses > 0 ? Color.Warning : Color.Default)">
                        <b>@_stats.ExpiringLicenses</b>
                    </MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Badge" Color="@(_stats.ExpiringLicenses > 0 ? Color.Warning : Color.Success)" Style="font-size:2rem;" />
                </div>
                <MudLink Href="/providers" Typo="Typo.caption" Color="Color.Primary">View Providers</MudLink>
            </MudPaper>
        </MudItem>

        @* Informational last *@
        <MudItem xs="6" sm="4" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="border-left: 4px solid var(--mud-palette-primary);">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Active Providers</MudText>
                <div class="d-flex align-center justify-space-between mt-1">
                    <MudText Typo="Typo.h4"><b>@_stats.ActiveProviders</b></MudText>
                    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Style="font-size:2rem;" />
                </div>
                <MudLink Href="/providers?col_IsActive=true" Typo="Typo.caption" Color="Color.Primary">View Providers</MudLink>
            </MudPaper>
        </MudItem>

    </MudGrid>
}

@* ── Detail Tables ────────────────────────────────────────── *@
@if (_operationAlerts == null)
{
    @* Loading state — show skeletons for the two primary tables *@
    <MudGrid Spacing="3">
        @for (int i = 0; i < 2; i++)
        {
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-3" Elevation="1">
                    @for (int j = 0; j < 5; j++) { <MudSkeleton Width="100%" Height="28px" Class="mb-1" /> }
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}
else if (_allClear)
{
    <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.CheckCircle" Class="mt-2">
        <MudText Typo="Typo.body1"><b>All clear.</b> No alerts, expiring approvals, pending evals, discrepancies, or expiring licenses.</MudText>
    </MudAlert>
}
else
{
    <MudGrid Spacing="3">

        @* Operation Alerts — only shown when there are items *@
        @if (_operationAlerts.Count > 0)
        {
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-2">
                    Operation Alerts
                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="ml-2">@_stats!.OperationAlerts total</MudChip>
                </MudText>
                <MudPaper Elevation="1">
                    <MudTable Items="_operationAlerts" Dense="true" Hover="true" Striped="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Student</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Flags</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="white-space:nowrap;">@context.StudentLastName, @context.StudentFirstName</MudTd>
                            <MudTd Style="white-space:nowrap;">@context.ServiceDate?.ToString("MM/dd/yyyy")</MudTd>
                            <MudTd>
                                <div class="d-flex gap-1 flex-wrap">
                                    @if (context.MandateFlag)    { <MudTooltip Text="Missing Approval"><MudIcon Icon="@Icons.Material.Filled.AssignmentLate" Color="Color.Error" Size="Size.Small" /></MudTooltip> }
                                    @if (context.ProviderFlag)   { <MudTooltip Text="Unassigned Provider"><MudIcon Icon="@Icons.Material.Filled.PersonOff" Color="Color.Error" Size="Size.Small" /></MudTooltip> }
                                    @if (context.IsOverlap)      { <MudTooltip Text="Overlap Service"><MudIcon Icon="@Icons.Material.Filled.EventRepeat" Color="Color.Error" Size="Size.Small" /></MudTooltip> }
                                    @if (context.IsOverMandate)  { <MudTooltip Text="Over Mandate"><MudIcon Icon="@Icons.Material.Filled.LibraryAddCheck" Color="Color.Error" Size="Size.Small" /></MudTooltip> }
                                    @if (context.IsOverDuration) { <MudTooltip Text="Over Duration"><MudIcon Icon="@Icons.Material.Filled.TimerOff" Color="Color.Warning" Size="Size.Small" /></MudTooltip> }
                                    @if (context.IsUnderGroup)   { <MudTooltip Text="Under Group Size"><MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Info" Size="Size.Small" /></MudTooltip> }
                                    @if (context.BRateFlag)      { <MudTooltip Text="Missing Billing Rate"><MudIcon Icon="@Icons.Material.Filled.MoneyOff" Color="Color.Warning" Size="Size.Small" /></MudTooltip> }
                                    @if (context.PRateFlag)      { <MudTooltip Text="Missing Provider Rate"><MudIcon Icon="@Icons.Material.Filled.MoneyOff" Color="Color.Warning" Size="Size.Small" /></MudTooltip> }
                                </div>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                    <div class="d-flex justify-end pa-2">
                        <MudLink Href="/operations" Typo="Typo.caption" Color="Color.Primary">View all operations</MudLink>
                    </div>
                </MudPaper>
            </MudItem>
        }

        @* Expiring Approvals — only shown when there are items *@
        @if (_expiringApprovals != null && _expiringApprovals.Count > 0)
        {
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-2">
                    Expiring Approvals
                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="ml-2">@_stats!.ExpiringApprovals in 30 days</MudChip>
                </MudText>
                <MudPaper Elevation="1">
                    <MudTable Items="_expiringApprovals" Dense="true" Hover="true" Striped="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Student</MudTh>
                            <MudTh>Service</MudTh>
                            <MudTh>Expires</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="white-space:nowrap;">
                                <MudTooltip Text="@context.StudentId">
                                    <span>@context.StudentLastName, @context.StudentFirstName</span>
                                </MudTooltip>
                            </MudTd>
                            <MudTd>@context.ServiceType</MudTd>
                            <MudTd Style="white-space:nowrap;">
                                @{
                                    var daysLeft = (context.MandateEnd!.Value - DateTime.Today).Days;
                                    var chipColor = daysLeft <= 7 ? Color.Error : Color.Warning;
                                }
                                <MudChip T="string" Color="@chipColor" Size="Size.Small">
                                    @context.MandateEnd.Value.ToString("MM/dd/yyyy") (@daysLeft d)
                                </MudChip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                    <div class="d-flex justify-end pa-2">
                        <MudLink Href="@_expiringApprovalsUrl" Typo="Typo.caption" Color="Color.Primary">View all approvals</MudLink>
                    </div>
                </MudPaper>
            </MudItem>
        }

        @* Evals Pending Payment — only shown when there are items *@
        @if (_evalsPending != null && _evalsPending.Count > 0)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudText Typo="Typo.h6" Class="mb-2">
                    Evals Pending Payment
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Class="ml-2">@_stats!.EvalsPendingPayment total</MudChip>
                </MudText>
                <MudPaper Elevation="1">
                    <MudTable Items="_evalsPending" Dense="true" Hover="true" Striped="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Student</MudTh>
                            <MudTh>Service</MudTh>
                            <MudTh>Billed</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="white-space:nowrap;">@context.StudentLastName, @context.StudentFirstName</MudTd>
                            <MudTd>@context.ServiceType</MudTd>
                            <MudTd Style="white-space:nowrap;">@context.BilledDate?.ToString("MM/dd/yyyy")</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <div class="d-flex justify-end pa-2">
                        <MudLink Href="/evaluations?col_BilledDate=notnull&col_BillPaidDate=null" Typo="Typo.caption" Color="Color.Primary">View all evaluations</MudLink>
                    </div>
                </MudPaper>
            </MudItem>
        }

        @* Vendor Portal Discrepancies — only shown when there are items *@
        @if (_discrepancies != null && _discrepancies.Count > 0)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudText Typo="Typo.h6" Class="mb-2">
                    Unmatched Vendor Portal
                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="ml-2">@_stats!.VendorPortalDiscrepancies total</MudChip>
                </MudText>
                <MudPaper Elevation="1">
                    <MudTable Items="_discrepancies" Dense="true" Hover="true" Striped="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Student</MudTh>
                            <MudTh>Provider</MudTh>
                            <MudTh>Start Date</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="white-space:nowrap;">@context.StudentLastName, @context.StudentFirstName</MudTd>
                            <MudTd Style="white-space:nowrap;">@context.ProviderLastName, @context.ProviderFirstName</MudTd>
                            <MudTd Style="white-space:nowrap;">@context.StartDate?.ToString("MM/dd/yyyy")</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <div class="d-flex justify-end pa-2">
                        <MudLink Href="/vendorportal?col_MismatchedVendorPortal=true" Typo="Typo.caption" Color="Color.Primary">View all discrepancies</MudLink>
                    </div>
                </MudPaper>
            </MudItem>
        }

        @* Expiring Licenses — only shown when there are items *@
        @if (_expiringLicenses != null && _expiringLicenses.Count > 0)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudText Typo="Typo.h6" Class="mb-2">
                    Expiring Licenses
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Class="ml-2">@_stats!.ExpiringLicenses within 60 days</MudChip>
                </MudText>
                <MudPaper Elevation="1">
                    <MudTable Items="_expiringLicenses" Dense="true" Hover="true" Striped="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Provider</MudTh>
                            <MudTh>License</MudTh>
                            <MudTh>Expires</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="white-space:nowrap;">@context.LastName, @context.FirstName</MudTd>
                            <MudTd>@context.LicenseNumber</MudTd>
                            <MudTd Style="white-space:nowrap;">
                                @{
                                    var expired = context.ExpirationDate < DateTime.Today;
                                    var daysLeft2 = (context.ExpirationDate - DateTime.Today).Days;
                                }
                                <MudChip T="string" Color="@(expired ? Color.Error : Color.Warning)" Size="Size.Small">
                                    @context.ExpirationDate.ToString("MM/dd/yyyy") @(expired ? "(Expired)" : $"({daysLeft2}d)")
                                </MudChip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                    <div class="d-flex justify-end pa-2">
                        <MudLink Href="/providers" Typo="Typo.caption" Color="Color.Primary">View all providers</MudLink>
                    </div>
                </MudPaper>
            </MudItem>
        }

    </MudGrid>
}

@code {
    private string _expiringApprovalsUrl =>
        $"/approvals?col_MandateEnd_From={DateTime.Today:yyyy-MM-dd}&col_MandateEnd_To={DateTime.Today.AddDays(30):yyyy-MM-dd}";

    private bool _allClear =>
        _stats != null &&
        _operationAlerts != null &&
        _stats.OperationAlerts == 0 &&
        _stats.ExpiringApprovals == 0 &&
        _stats.UnbilledSessions == 0 &&
        _stats.EvalsPendingPayment == 0 &&
        _stats.VendorPortalDiscrepancies == 0 &&
        _stats.ExpiringLicenses == 0;

    private DashboardStats?             _stats;
    private List<OperationAlertItem>?   _operationAlerts;
    private List<DiscrepancyItem>?      _discrepancies;
    private List<EvalPendingItem>?      _evalsPending;
    private List<ExpiringApprovalItem>? _expiringApprovals;
    private List<ExpiringLicenseItem>?  _expiringLicenses;

    protected override async Task OnInitializedAsync()
    {
        var statsTask       = DashboardService.GetStatsAsync();
        var alertsTask      = DashboardService.GetOperationAlertsAsync(15);
        var discrepancyTask = DashboardService.GetVendorPortalDiscrepanciesAsync(15);
        var evalsTask       = DashboardService.GetEvalsPendingPaymentAsync(15);
        var expiringTask    = DashboardService.GetExpiringApprovalsAsync(30, 15);
        var licensesTask    = DashboardService.GetExpiringLicensesAsync(60, 15);

        await Task.WhenAll(statsTask, alertsTask, discrepancyTask, evalsTask, expiringTask, licensesTask);

        _stats             = await statsTask;
        _operationAlerts   = await alertsTask;
        _discrepancies     = await discrepancyTask;
        _evalsPending      = await evalsTask;
        _expiringApprovals = await expiringTask;
        _expiringLicenses  = await licensesTask;
    }
}
