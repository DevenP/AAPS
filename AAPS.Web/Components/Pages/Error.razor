@page "/Error"
@using System.Diagnostics
@rendermode InteractiveServer

<PageTitle>System Error</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
    <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" Style="font-size: 5rem;" />

    <MudText Typo="Typo.h3" Color="Color.Error" Class="mb-4">Oops!</MudText>
    <MudText Typo="Typo.h6">An error occurred while processing your request.</MudText>

    @if (ShowRequestId)
    {
        <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Class="mt-6">
            <strong>Request ID:</strong> <code>@RequestId</code>
        </MudAlert>
    }

    <MudButton Variant="Variant.Filled" Color="Color.Primary" href="/" Class="mt-8">
        Back to Dashboard
    </MudButton>

    <MudExpansionPanels Class="mt-10">
        <MudExpansionPanel Text="Technical Details (Admin Only)">
            <MudText Typo="Typo.body2" Align="Align.Left">
                The Development environment should not be enabled for deployed applications as it can result in displaying sensitive information.
            </MudText>
        </MudExpansionPanel>
    </MudExpansionPanels>
</MudContainer>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }
    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
