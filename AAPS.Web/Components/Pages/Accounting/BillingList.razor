@page "/billing"
@using AAPS.Application.Abstractions.Services
@using AAPS.Application.Common.Paging
@using Microsoft.AspNetCore.Hosting
@using AAPS.Application.DTO
@using AAPS.Web.Components.Pages.Accounting.Forms
@using AAPS.Web.Components.Shared
@inject IBillingService BillingService
@inject IStatementService StatementService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject ILogger<BillingList> Logger

<GenericGrid @ref="_grid" TItem="BillingRecordDTO"
             Title="Billing"
             Columns="@(new[] { "Checkbox", "Actions", "DateOfService", "StartTime", "EndTime", "Provider", "StudentId", "Student", "ServiceType", "Frequency", "Duration", "ActualSize", "EntryId", "AssignId", "Billed", "Voucher", "VoucherAmount", "UnpaidBalance", "VoucherBalancePaid", "ProviderPaidOn", "ProviderAmount", "BillingRate", "ProviderRate", "SesisId" })"
             GetData="BillingService.GetPagedAsync"
             DefaultSortLabel="DateOfService"
             OnDataLoaded="RefreshSummary"
             OnFilterRemoved="@(_ => { ClearSelection(); return Task.CompletedTask; })"
             OnFiltersChanged="ClearSelection"
             ExportMapper="@(r => new object?[] { r.DateOfService?.ToString("MM/dd/yyyy"), r.StartTime, r.EndTime, r.Provider, r.StudentId, r.Student, r.ServiceType, r.Frequency, r.Duration, r.ActualSize, r.EntryId, r.AssignId, r.Billed?.ToString("MM/dd/yyyy"), r.Voucher, r.VoucherAmount, r.UnpaidBalance, r.VoucherBalancePaid?.ToString("MM/dd/yyyy"), r.ProviderPaidOn?.ToString("MM/dd/yyyy"), r.ProviderAmount, r.BillingRate, r.ProviderRate, r.SesisId })">

    <CustomActionContent>
        @if (_selectedIds.Count > 0)
        {
            <MudText Typo="Typo.caption" Class="mr-2 align-self-center">@_selectedIds.Count selected</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Deselect" Title="Clear selection" Size="Size.Small" OnClick="ClearSelection" Class="mr-1" />
        }
        @ActionButtons
    </CustomActionContent>

    <HeaderContent>
        <MudTh Style="width:40px; padding: 0 8px;">
            <MudCheckBox T="bool" Value="_allSelected" ValueChanged="ToggleSelectAll" Color="Color.Primary" Size="Size.Small" />
        </MudTh>
        <GridCell TItem="BillingRecordDTO" Column="Actions" IsHeader="true">Actions</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="DateOfService" IsHeader="true">
            <MudTableSortLabel SortLabel="DateOfService" T="BillingRecordDTO">@_grid.GetDisplayName("DateOfService")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="StartTime" IsHeader="true">
            <MudTableSortLabel SortLabel="StartTime" T="BillingRecordDTO">@_grid.GetDisplayName("StartTime")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="EndTime" IsHeader="true">@_grid.GetDisplayName("EndTime")</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="Provider" IsHeader="true">
            <MudTableSortLabel SortLabel="Provider" T="BillingRecordDTO">@_grid.GetDisplayName("Provider")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="StudentId" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentId" T="BillingRecordDTO">@_grid.GetDisplayName("StudentId")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="Student" IsHeader="true">
            <MudTableSortLabel SortLabel="Student" T="BillingRecordDTO">@_grid.GetDisplayName("Student")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="ServiceType" IsHeader="true">
            <MudTableSortLabel SortLabel="ServiceType" T="BillingRecordDTO">@_grid.GetDisplayName("ServiceType")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="Frequency" IsHeader="true">@_grid.GetDisplayName("Frequency")</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="Duration" IsHeader="true">@_grid.GetDisplayName("Duration")</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="ActualSize" IsHeader="true">@_grid.GetDisplayName("ActualSize")</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="EntryId" IsHeader="true">
            <MudTableSortLabel SortLabel="EntryId" T="BillingRecordDTO">@_grid.GetDisplayName("EntryId")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="AssignId" IsHeader="true">
            <MudTableSortLabel SortLabel="AssignId" T="BillingRecordDTO">@_grid.GetDisplayName("AssignId")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="Billed" IsHeader="true">
            <MudTableSortLabel SortLabel="Billed" T="BillingRecordDTO">@_grid.GetDisplayName("Billed")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="Voucher" IsHeader="true">
            <MudTableSortLabel SortLabel="Voucher" T="BillingRecordDTO">@_grid.GetDisplayName("Voucher")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="VoucherAmount" IsHeader="true">
            <MudTableSortLabel SortLabel="VoucherAmount" T="BillingRecordDTO">@_grid.GetDisplayName("VoucherAmount")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="UnpaidBalance" IsHeader="true">
            <MudTableSortLabel SortLabel="UnpaidBalance" T="BillingRecordDTO">@_grid.GetDisplayName("UnpaidBalance")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="VoucherBalancePaid" IsHeader="true">
            <MudTableSortLabel SortLabel="VoucherBalancePaid" T="BillingRecordDTO">@_grid.GetDisplayName("VoucherBalancePaid")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="ProviderPaidOn" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderPaidOn" T="BillingRecordDTO">@_grid.GetDisplayName("ProviderPaidOn")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="ProviderAmount" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderAmount" T="BillingRecordDTO">@_grid.GetDisplayName("ProviderAmount")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="BillingRate" IsHeader="true">
            <MudTableSortLabel SortLabel="BillingRate" T="BillingRecordDTO">@_grid.GetDisplayName("BillingRate")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="ProviderRate" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderRate" T="BillingRecordDTO">@_grid.GetDisplayName("ProviderRate")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="SesisId" IsHeader="true">
            <MudTableSortLabel SortLabel="SesisId" T="BillingRecordDTO">@_grid.GetDisplayName("SesisId")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="GDistrict" IsHeader="true">
            <MudTableSortLabel SortLabel="GDistrict" T="BillingRecordDTO">@_grid.GetDisplayName("GDistrict")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="Grade" IsHeader="true">
            <MudTableSortLabel SortLabel="Grade" T="BillingRecordDTO">@_grid.GetDisplayName("Grade")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="BilledPaidOn" IsHeader="true">
            <MudTableSortLabel SortLabel="BilledPaidOn" T="BillingRecordDTO">@_grid.GetDisplayName("BilledPaidOn")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="BillingRecordDTO" Column="BillingAmount" IsHeader="true">
            <MudTableSortLabel SortLabel="BillingAmount" T="BillingRecordDTO">@_grid.GetDisplayName("BillingAmount")</MudTableSortLabel>
        </GridCell>
    </HeaderContent>

    <RowTemplate Context="record">
        <MudTd Style="width:40px; padding: 0 8px;" @onmousedown="@(e => _shiftHeld = e.ShiftKey)">
            <MudCheckBox T="bool"
                         Value="_selectedIds.Contains(record.SesisId)"
                         ValueChanged="@(v => ToggleRow(record.SesisId, v, _grid.CurrentPageItems.IndexOf(record)))"
                         Color="Color.Primary"
                         Size="Size.Small" />
        </MudTd>
        <GridCell TItem="BillingRecordDTO" Column="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Size="Size.Small" Color="Color.Primary"
                           Title="Edit Billing Dates"
                           OnClick="@(() => OpenEditDialog(record))" />
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="DateOfService">
            @record.DateOfService?.ToString("MM/dd/yyyy")
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="StartTime">@record.StartTime</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="EndTime">@record.EndTime</GridCell>

        <GridCell TItem="BillingRecordDTO" Column="Provider">
            <MudTooltip Text="@record.Provider">@record.Provider</MudTooltip>
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="StudentId">@record.StudentId</GridCell>

        <GridCell TItem="BillingRecordDTO" Column="Student">
            <MudTooltip Text="@record.Student">@record.Student</MudTooltip>
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="ServiceType">@record.ServiceType</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="Frequency">@record.Frequency</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="Duration">@record.Duration</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="ActualSize">@record.ActualSize</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="EntryId">@record.EntryId</GridCell>

        <GridCell TItem="BillingRecordDTO" Column="AssignId">
            <span style="font-family:monospace;">@record.AssignId</span>
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="Billed">
            @if (record.Billed.HasValue)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">
                    @record.Billed.Value.ToString("MM/dd/yyyy")
                </MudChip>
            }
            else
            {
                <MudText Typo="Typo.caption" Style="opacity:0.4;">—</MudText>
            }
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="Voucher">
            <span style="font-family:monospace;">@record.Voucher</span>
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="VoucherAmount">
            @record.VoucherAmount?.ToString("C2")
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="UnpaidBalance">
            @record.UnpaidBalance?.ToString("C2")
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="VoucherBalancePaid">
            @if (record.VoucherBalancePaid.HasValue)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">
                    @record.VoucherBalancePaid.Value.ToString("MM/dd/yyyy")
                </MudChip>
            }
            else
            {
                <MudText Typo="Typo.caption" Style="opacity:0.4;">—</MudText>
            }
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="ProviderPaidOn">
            @if (record.ProviderPaidOn.HasValue)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text">
                    @record.ProviderPaidOn.Value.ToString("MM/dd/yyyy")
                </MudChip>
            }
            else
            {
                <MudText Typo="Typo.caption" Style="opacity:0.4;">—</MudText>
            }
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="ProviderAmount">
            @record.ProviderAmount?.ToString("C2")
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="BillingRate">
            <MudText Color="Color.Primary" Style="font-weight:600;">@record.BillingRate?.ToString("C2")</MudText>
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="ProviderRate">
            @record.ProviderRate?.ToString("C2")
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="SesisId">
            <span style="font-family:monospace;">@record.SesisId</span>
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="GDistrict">@record.GDistrict</GridCell>
        <GridCell TItem="BillingRecordDTO" Column="Grade">@record.Grade</GridCell>

        <GridCell TItem="BillingRecordDTO" Column="BilledPaidOn">
            @if (record.BilledPaidOn.HasValue)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">
                    @record.BilledPaidOn.Value.ToString("MM/dd/yyyy")
                </MudChip>
            }
            else
            {
                <MudText Typo="Typo.caption" Style="opacity:0.4;">—</MudText>
            }
        </GridCell>

        <GridCell TItem="BillingRecordDTO" Column="BillingAmount">
            <MudText Color="Color.Success" Style="font-weight:600;">@record.BillingAmount?.ToString("C2")</MudText>
        </GridCell>
    </RowTemplate>

</GenericGrid>

@code {
    private GenericGrid<BillingRecordDTO> _grid = default!;
    private bool _generating = false;
    private bool _generatingStatements = false;
    private BillingSummary? _summary;
    private HashSet<int> _selectedIds = [];
    private bool _allSelected = false;
    private bool _busy = false;

    private bool _isBusy => _generating || _generatingStatements;

    // ── Selection ────────────────────────────────────────────────────────────
    private bool _shiftHeld = false;
    private int _lastClickedIndex = -1;

    private void ToggleRow(int id, bool selected, int index)
    {
        if (_shiftHeld && _lastClickedIndex >= 0)
        {
            var items = _grid.CurrentPageItems;
            var from = Math.Min(_lastClickedIndex, index);
            var to = Math.Max(_lastClickedIndex, index);
            for (int i = from; i <= to; i++)
            {
                if (selected) _selectedIds.Add(items[i].SesisId);
                else _selectedIds.Remove(items[i].SesisId);
            }
        }
        else
        {
            if (selected) _selectedIds.Add(id);
            else _selectedIds.Remove(id);
        }
        _lastClickedIndex = index;
        _allSelected = false;
    }

    private async Task ToggleSelectAll(bool selected)
    {
        _allSelected = selected;
        if (!selected) { _selectedIds.Clear(); return; }
        var request = new PagedRequest(_grid.Search, _grid.ColumnFilters);
        _selectedIds = (await BillingService.GetIdsAsync(request)).ToHashSet();
    }

    private void ClearSelection()
    {
        _selectedIds.Clear();
        _allSelected = false;
        _lastClickedIndex = -1;
    }

    // ── Bulk edit ────────────────────────────────────────────────────────────
    private async Task OpenBulkEditDialog()
    {
        var parameters = new DialogParameters<BillingEditDialog>
        {
            { x => x.Item, new BillingRecordDTO() },
            { x => x.IsBulk, true },
            { x => x.SelectedCount, _selectedIds.Count }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<BillingEditDialog>("Edit Fields", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        if (result.Data is ValueTuple<DateTime?, DateTime?, DateTime?> bulk)
            await RunBulkUpdate(bulk.Item1 != null, bulk.Item1, bulk.Item2 != null, bulk.Item2, bulk.Item3 != null, bulk.Item3);
    }

    private async Task RunBulkUpdate(bool applyBilled, DateTime? billed, bool applyBilledPaid, DateTime? billedPaid, bool applyProviderPaid, DateTime? providerPaid)
    {
        var ids = _selectedIds.ToList();
        _busy = true;
        StateHasChanged();
        try
        {
            await BillingService.BulkUpdateBillingDatesAsync(ids, applyBilled, billed, applyBilledPaid, billedPaid, applyProviderPaid, providerPaid);
            Snackbar.Add($"{ids.Count} record(s) updated.", Severity.Success);
            ClearSelection();
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Bulk billing date update failed");
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RefreshSummary()
    {
        _summary = await BillingService.GetSummaryAsync(_grid.Search, _grid.ColumnFilters);
        StateHasChanged();
    }

    private RenderFragment ActionButtons =>
        @<span style="display:inline-flex;align-items:center;gap:12px;">
            @if (_summary != null)
            {
                <span style="display:inline-flex;align-items:center;gap:8px;font-size:0.8rem;">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@_summary.Count records</MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success">Billed @_summary.TotalBilling.ToString("C2")</MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">Providers Paid @_summary.TotalProvider.ToString("C2")</MudChip>
                </span>
            }
            @if (_isBusy || _busy)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="true">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    Working…
                </MudButton>
            }
            else
            {
                <MudMenu Label="Actions"
                         Variant="Variant.Filled"
                         Color="Color.Primary"
                         EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                         Size="Size.Small">
                    @if (_selectedIds.Count == 0)
                    {
                        <MudTooltip Text="Select rows to enable bulk editing">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" Disabled="true">
                                Edit Fields
                            </MudMenuItem>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="OpenBulkEditDialog">
                            Edit Fields
                        </MudMenuItem>
                    }
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.FileOpen"
                                 OnClick="GenerateFiles">
                        Generate Billing Files
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Description"
                                 OnClick="GenerateStatements">
                        Generate Statements
                    </MudMenuItem>
                </MudMenu>
            }
        </span>;

    private async Task GenerateStatements()
    {
        _generatingStatements = true;
        try
        {
            var headerPath = Path.Combine(Env.WebRootPath, "images", "rs-header.jpg");
            var footerPath = Path.Combine(Env.WebRootPath, "images", "rs-footer.jpg");
            StatementService.SetLogoPaths(headerPath, footerPath);

            var selected = _selectedIds.Count > 0 ? _selectedIds.ToList() : null;
            var statementFiles = await StatementService.GenerateAsync(_grid.Search, _grid.ColumnFilters, selected);

            if (statementFiles.Count == 0)
            {
                Snackbar.Add("No records found to generate statements from.", Severity.Info);
                return;
            }

            var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = false, CloseButton = true };
            var parameters = new DialogParameters<BillingFilesDownloadDialog>
            {
                { x => x.StatementFiles, statementFiles }
            };
            await DialogService.ShowAsync<BillingFilesDownloadDialog>($"{statementFiles.Count} Statement(s) Generated", parameters, options);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error generating statements");
            var msg = ex.Message.Split('\n')[0].Trim();
            if (msg.Length > 120) msg = msg[..120] + "…";
            Snackbar.Add($"Error generating statements: {msg}", Severity.Error);
        }
        finally
        {
            _generatingStatements = false;
        }
    }

    private async Task GenerateFiles()
    {
        _generating = true;
        try
        {
            var selected = _selectedIds.Count > 0 ? _selectedIds.ToList() : null;
            var generateResult = await BillingService.GenerateBillingFilesAsync(_grid.Search, _grid.ColumnFilters, selected);

            if (generateResult.SkippedPaidCount > 0)
                Snackbar.Add($"{generateResult.SkippedPaidCount} selected record(s) were already paid and were skipped.", Severity.Warning);

            if (generateResult.Files.Count == 0)
            {
                Snackbar.Add("No unbilled records found to generate files from.", Severity.Info);
                return;
            }

            Snackbar.Add($"{generateResult.Files.Count} billing file(s) saved to disk.", Severity.Success);

            var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = false, CloseButton = true };
            var parameters = new DialogParameters<BillingFilesDownloadDialog>
            {
                { x => x.Files, generateResult.Files }
            };
            await DialogService.ShowAsync<BillingFilesDownloadDialog>("Billing Files Generated", parameters, options);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error generating billing files");
            var msg = ex.Message.Split('\n')[0].Trim();
            if (msg.Length > 120) msg = msg[..120] + "…";
            Snackbar.Add($"Error generating files: {msg}", Severity.Error);
        }
        finally
        {
            _generating = false;
        }
    }

    private async Task OpenEditDialog(BillingRecordDTO record)
    {
        var parameters = new DialogParameters<BillingEditDialog>
        {
            { x => x.Item, record }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<BillingEditDialog>("Edit Billing Dates", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        if (result.Data is ValueTuple<DateTime?, DateTime?, DateTime?> dates)
        {
            try
            {
                await BillingService.UpdateBillingDatesAsync(record.SesisId, dates.Item1, dates.Item2, dates.Item3);
                Snackbar.Add("Billing dates updated.", Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error updating billing dates for SesisId {SesisId}", record.SesisId);
                Snackbar.Add($"Error saving: {ex.Message}", Severity.Error);
            }
        }
    }
}
