@page "/not-found"
@layout MainLayout

<PageTitle>Page Not Found — AAPS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-6" Icon="@Icons.Material.Filled.SearchOff">
        <MudText Typo="Typo.h6" Class="font-weight-bold">Page Not Found</MudText>
        <MudText Typo="Typo.body2" Class="mt-1">
            The page you're looking for doesn't exist or may have been moved.
        </MudText>
    </MudAlert>

    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" StartIcon="@Icons.Material.Filled.Home">
        Back to Dashboard
    </MudButton>
</MudContainer>