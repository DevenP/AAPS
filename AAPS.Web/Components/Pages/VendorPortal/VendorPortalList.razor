@page "/vendorportal"
@using AAPS.Application.Abstractions.Services
@using AAPS.Application.Common.Extensions
@using AAPS.Application.DTO
@using AAPS.Web.Components.Shared
@using System.Reflection
@inject IVendorPortalService VendorPortalService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<GenericGrid TItem="VendorPortalDTO"
             @ref="_grid"
             Title="Vendor Portal"
             Columns="@(new[] { "Mismatch", "StudentId", "StudentLastName", "StudentFirstName", "ProviderLastName", "ProviderFirstName", "ProviderSSN", "Duration", "Frequency", "GroupSize", "School", "ApprovalStartDate", "AssignmentId", "Fund", "VenderPortalFile", "EntryId" })"
             GetData="VendorPortalService.GetPagedAsync"
             OnFilterRemoved="OnFilterRemoved">

    <CustomActionContent>

        @if (_selectedIds.Count > 0)
        {
            <MudText Typo="Typo.caption" Class="mr-2 align-self-center">
                @_selectedIds.Count selected
            </MudText>

            <MudMenu Label="Actions"
                     Variant="Variant.Filled"
                     Color="Color.Primary"
                     EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                     Size="Size.Small"
                     Class="mr-2">
                <MudMenuItem Icon="@Icons.Material.Filled.SwapHoriz"
                             OnClick="OpenReplaceApprovalId">
                    Replace Approval ID
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.DeleteForever"
                             IconColor="Color.Error"
                             OnClick="ConfirmRemoveSelected">
                    <MudText Color="Color.Error">Remove Discrepancy Record</MudText>
                </MudMenuItem>
            </MudMenu>

            <MudIconButton Icon="@Icons.Material.Filled.Deselect"
                           Title="Clear selection"
                           Size="Size.Small"
                           OnClick="ClearSelection" />
        }

    </CustomActionContent>

    <HeaderContent>
        <MudTh Style="width:40px; padding: 0 8px;">
            <MudCheckBox T="bool"
                         Value="_allSelected"
                         ValueChanged="ToggleSelectAll"
                         Color="Color.Primary"
                         Size="Size.Small" />
        </MudTh>

        <GridCell TItem="VendorPortalDTO" Column="Mismatch" IsHeader="true">
            <MudTableSortLabel SortLabel="Mismatch" T="VendorPortalDTO">@_grid?.GetDisplayName("Mismatch")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="StudentId" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentId" T="VendorPortalDTO">@_grid?.GetDisplayName("StudentId")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="StudentLastName" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentLastName" T="VendorPortalDTO">@_grid?.GetDisplayName("StudentLastName")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="StudentFirstName" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentFirstName" T="VendorPortalDTO">@_grid?.GetDisplayName("StudentFirstName")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="ProviderLastName" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderLastName" T="VendorPortalDTO">@_grid?.GetDisplayName("ProviderLastName")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="ProviderFirstName" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderFirstName" T="VendorPortalDTO">@_grid?.GetDisplayName("ProviderFirstName")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="ProviderSSN" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderSSN" T="VendorPortalDTO">@_grid?.GetDisplayName("ProviderSSN")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="Duration" IsHeader="true">
            @_grid?.GetDisplayName("Duration")
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="Frequency" IsHeader="true">
            @_grid?.GetDisplayName("Frequency")
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="GroupSize" IsHeader="true">
            @_grid?.GetDisplayName("GroupSize")
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="School" IsHeader="true">
            <MudTableSortLabel SortLabel="School" T="VendorPortalDTO">@_grid?.GetDisplayName("School")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="ApprovalStartDate" IsHeader="true">
            <MudTableSortLabel SortLabel="ApprovalStartDate" T="VendorPortalDTO">@_grid?.GetDisplayName("ApprovalStartDate")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="AssignmentId" IsHeader="true">
            <MudTableSortLabel SortLabel="AssignmentId" T="VendorPortalDTO">@_grid?.GetDisplayName("AssignmentId")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="Fund" IsHeader="true">
            <MudTableSortLabel SortLabel="Fund" T="VendorPortalDTO">@_grid?.GetDisplayName("Fund")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="VenderPortalFile" IsHeader="true">
            <MudTableSortLabel SortLabel="VenderPortalFile" T="VendorPortalDTO">@_grid?.GetDisplayName("VenderPortalFile")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="EntryId" IsHeader="true">
            <MudTableSortLabel SortLabel="EntryId" T="VendorPortalDTO">@_grid?.GetDisplayName("EntryId")</MudTableSortLabel>
        </GridCell>
    </HeaderContent>

    <RowTemplate Context="item">
        <MudTd Style="width:40px; padding: 0 8px;">
            <MudCheckBox T="bool"
                         Value="_selectedIds.Contains(item.Id)"
                         ValueChanged="@(v => ToggleRow(item.Id, v))"
                         Color="Color.Primary"
                         Size="Size.Small" />
        </MudTd>

        <GridCell TItem="VendorPortalDTO" Column="Mismatch">@item.Mismatch</GridCell>

        <GridCell TItem="VendorPortalDTO" Column="StudentId">@item.StudentId</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="StudentLastName">@item.StudentLastName</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="StudentFirstName">@item.StudentFirstName</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="ProviderLastName">@item.ProviderLastName</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="ProviderFirstName">@item.ProviderFirstName</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="ProviderSSN">
            <span style="font-family:monospace;">@item.ProviderSSN</span>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="Duration">@item.Duration</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="Frequency">@item.Frequency</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="GroupSize">@item.GroupSize</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="School">@item.School</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="ApprovalStartDate">
            <MudTooltip Text="@item.ApprovalStartDate?.ToLongDateString()">
                <span>@item.ApprovalStartDate?.ToString("MM/dd/yyyy")</span>
            </MudTooltip>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="AssignmentId">
            <span style="font-family:monospace;">@item.AssignmentId</span>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="Fund">@item.Fund</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="VenderPortalFile">
            <MudTooltip Text="@item.VenderPortalFile">
                <span style="max-width:150px; display:inline-block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    @item.VenderPortalFile
                </span>
            </MudTooltip>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="EntryId">
            @if (item.EntryId.HasValue)
            {
                <span style="font-family:monospace;">@item.EntryId</span>
            }
            else
            {
                <MudText Typo="Typo.caption" Style="opacity:0.4;">—</MudText>
            }
        </GridCell>
    </RowTemplate>

</GenericGrid>

@code {
    private GenericGrid<VendorPortalDTO> _grid = default!;

    // ── Selection state ──────────────────────────────────────────────────────
    private HashSet<int> _selectedIds = new();
    private bool _allSelected = false;

    private void ToggleRow(int id, bool selected)
    {
        if (selected) _selectedIds.Add(id);
        else _selectedIds.Remove(id);
        _allSelected = false;
    }

    private async Task ToggleSelectAll(bool selected)
    {
        _allSelected = selected;
        if (!selected)
        {
            _selectedIds.Clear();
            return;
        }

        var request = new AAPS.Application.Common.Paging.PagedRequest(
            _grid.ColumnFilters.TryGetValue("Global", out var s) ? s : "",
            _grid.ColumnFilters,
            PageSize: -1);
        var result = await VendorPortalService.GetPagedAsync(request);
        _selectedIds = result.Items.Select(i => i.Id).ToHashSet();
    }

    private void ClearSelection()
    {
        _selectedIds.Clear();
        _allSelected = false;
    }

    // ── Remove Discrepancy Record ────────────────────────────────────────────
    private async Task ConfirmRemoveSelected()
    {
        var idsToDelete = _selectedIds.ToList();
        var count = idsToDelete.Count;

        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "CONFIRMATION DIALOG.",
            $"PLEASE CONFIRM TO PROCEED — this will permanently delete {count} record{(count == 1 ? "" : "s")}.",
            yesText: "Yes, Delete",
            cancelText: "Cancel");

        if (confirmed != true) return;

        try
        {
            await VendorPortalService.DeleteManyAsync(idsToDelete);
            ClearSelection();
            Snackbar.Add($"{count} discrepancy record{(count == 1 ? "" : "s")} removed.", Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    // ── Replace Approval ID ──────────────────────────────────────────────────
    private async Task OpenReplaceApprovalId()
    {
        var idsToUpdate = _selectedIds.ToList();
        var count = idsToUpdate.Count;

        var parameters = new DialogParameters { ["SelectedCount"] = count };
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ReplaceApprovalIdDialog>(
            "Replace Approval ID", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        int newEntryId = (int)result.Data!;

        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "CONFIRMATION DIALOG.",
            $"PLEASE CONFIRM TO PROCEED — this will replace the Approval ID on {count} record{(count == 1 ? "" : "s")} with {newEntryId}.",
            yesText: "Yes, Replace",
            cancelText: "Cancel");

        if (confirmed != true) return;

        try
        {
            await VendorPortalService.ReplaceEntryIdAsync(idsToUpdate, newEntryId);
            ClearSelection();
            Snackbar.Add($"Approval ID updated to {newEntryId} on {count} record(s).", Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Update failed: {ex.Message}", Severity.Error);
        }
    }

    private Task OnFilterRemoved(string key)
    {
        ClearSelection();
        return Task.CompletedTask;
    }
}
