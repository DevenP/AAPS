@page "/vendorportal"
@using AAPS.Application.Abstractions.Services
@using AAPS.Application.DTO
@using AAPS.Web.Components.Shared
@inject IVendorPortalService VendorPortalService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<GenericGrid TItem="VendorPortalDTO"
             @ref="_grid"
             Title="Vendor Portal"
             Columns="@(new[] { "Id", "Mismatch", "AssignmentId", "StudentId", "StudentLastName", "ProviderLastName", "ApprovalStartDate", "VenderPortalFile", "EntryId" })"
             GetData="VendorPortalService.GetPagedAsync"
             OnFilterRemoved="OnFilterRemoved">

    <CustomActionContent>

        @if (_selectedIds.Count > 0)
        {
            <MudText Typo="Typo.caption" Class="mr-2 align-self-center">
                @_selectedIds.Count selected
            </MudText>

            <MudMenu Label="Actions"
                     Variant="Variant.Filled"
                     Color="Color.Primary"
                     EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                     Size="Size.Small"
                     Class="mr-2">
                <MudMenuItem Icon="@Icons.Material.Filled.SwapHoriz"
                             OnClick="OpenReplaceApprovalId">
                    Replace Approval ID
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.DeleteForever"
                             IconColor="Color.Error"
                             OnClick="ConfirmRemoveSelected">
                    <MudText Color="Color.Error">Remove Discrepancy Record</MudText>
                </MudMenuItem>
            </MudMenu>

            <MudIconButton Icon="@Icons.Material.Filled.Deselect"
                           Title="Clear selection"
                           Size="Size.Small"
                           OnClick="ClearSelection" />
        }

    </CustomActionContent>

    <HeaderContent>
        <MudTh Style="width:40px; padding: 0 8px;">
            <MudCheckBox T="bool"
                         Value="_allSelected"
                         ValueChanged="ToggleSelectAll"
                         Color="Color.Primary"
                         Size="Size.Small" />
        </MudTh>

        <GridCell TItem="VendorPortalDTO" Column="Id" IsHeader="true">
            <MudTableSortLabel SortLabel="Id" T="VendorPortalDTO">ID</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="Mismatch" IsHeader="true">Match Status</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="AssignmentId" IsHeader="true">
            <MudTableSortLabel SortLabel="AssignmentId" T="VendorPortalDTO">Assign ID</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="StudentId" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentId" T="VendorPortalDTO">Student ID</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="StudentLastName" IsHeader="true">Student</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="ProviderLastName" IsHeader="true">Provider</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="ApprovalStartDate" IsHeader="true">
            <MudTableSortLabel SortLabel="ApprovalStartDate" T="VendorPortalDTO">Start Date</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="VendorPortalDTO" Column="VenderPortalFile" IsHeader="true">File Source</GridCell>
        <GridCell TItem="VendorPortalDTO" Column="EntryId" IsHeader="true">
            <MudTableSortLabel SortLabel="EntryId" T="VendorPortalDTO">Approval ID</MudTableSortLabel>
        </GridCell>
    </HeaderContent>

    <RowTemplate Context="item">
        <MudTd Style="width:40px; padding: 0 8px;">
            <MudCheckBox T="bool"
                         Value="_selectedIds.Contains(item.Id)"
                         ValueChanged="@(v => ToggleRow(item.Id, v))"
                         Color="Color.Primary"
                         Size="Size.Small" />
        </MudTd>

        <GridCell TItem="VendorPortalDTO" Column="Id">@item.Id</GridCell>

        <GridCell TItem="VendorPortalDTO" Column="Mismatch">
            @if (item.Mismatch == "Approval")
            {
                <MudTooltip Text="Mismatch: No Matching Approval/Mandate found">
                    <MudIcon Icon="@Icons.Material.Filled.AssignmentLate" Color="Color.Error" Size="Size.Small" />
                </MudTooltip>
            }
            else if (item.Mismatch == "Provider")
            {
                <MudTooltip Text="Mismatch: Provider SSN not found in internal records">
                    <MudIcon Icon="@Icons.Material.Filled.PersonOff" Color="Color.Warning" Size="Size.Small" />
                </MudTooltip>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
            }
        </GridCell>

        <GridCell TItem="VendorPortalDTO" Column="AssignmentId">
            <span style="font-family: monospace;">@item.AssignmentId</span>
        </GridCell>

        <GridCell TItem="VendorPortalDTO" Column="StudentId">@item.StudentId</GridCell>

        <GridCell TItem="VendorPortalDTO" Column="StudentLastName">
            <MudTooltip Text="@($"{item.StudentLastName}, {item.StudentFirstName}")">
                <span>@item.StudentLastName</span>
            </MudTooltip>
        </GridCell>

        <GridCell TItem="VendorPortalDTO" Column="ProviderLastName">
            <MudTooltip Text="@($"{item.ProviderLastName}, {item.ProviderFirstName}")">
                <span>@item.ProviderLastName</span>
            </MudTooltip>
        </GridCell>

        <GridCell TItem="VendorPortalDTO" Column="ApprovalStartDate">
            @item.ApprovalStartDate?.ToString("MM/dd/yyyy")
        </GridCell>

        <GridCell TItem="VendorPortalDTO" Column="VenderPortalFile">
            <MudTooltip Text="@item.VenderPortalFile">
                <span style="max-width: 150px; display: inline-block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    @item.VenderPortalFile
                </span>
            </MudTooltip>
        </GridCell>

        <GridCell TItem="VendorPortalDTO" Column="EntryId">
            @if (item.EntryId.HasValue)
            {
                <span style="font-family: monospace;">@item.EntryId</span>
            }
            else
            {
                <MudText Typo="Typo.caption" Style="opacity:0.4;">—</MudText>
            }
        </GridCell>
    </RowTemplate>

</GenericGrid>

@code {
    private GenericGrid<VendorPortalDTO> _grid = default!;

    // ── Selection state ──────────────────────────────────────────────────────
    private HashSet<int> _selectedIds = new();
    private bool _allSelected = false;

    private void ToggleRow(int id, bool selected)
    {
        if (selected) _selectedIds.Add(id);
        else _selectedIds.Remove(id);
        _allSelected = false;
    }

    private async Task ToggleSelectAll(bool selected)
    {
        _allSelected = selected;
        if (!selected)
        {
            _selectedIds.Clear();
            return;
        }

        var request = new AAPS.Application.Common.Paging.PagedRequest(
            _grid.ColumnFilters.TryGetValue("Global", out var s) ? s : "",
            _grid.ColumnFilters,
            PageSize: -1);
        var result = await VendorPortalService.GetPagedAsync(request);
        _selectedIds = result.Items.Select(i => i.Id).ToHashSet();
    }

    private void ClearSelection()
    {
        _selectedIds.Clear();
        _allSelected = false;
    }

    // ── Remove Discrepancy Record ────────────────────────────────────────────
    private async Task ConfirmRemoveSelected()
    {
        var idsToDelete = _selectedIds.ToList();
        var count = idsToDelete.Count;

        bool? confirmed = await DialogService.ShowMessageBox(
            "CONFIRMATION DIALOG.",
            $"PLEASE CONFIRM TO PROCEED — this will permanently delete {count} record{(count == 1 ? "" : "s")}.",
            yesText: "Yes, Delete",
            cancelText: "Cancel");

        if (confirmed != true) return;

        await VendorPortalService.DeleteManyAsync(idsToDelete);
        ClearSelection();
        Snackbar.Add($"{count} discrepancy record{(count == 1 ? "" : "s")} removed.", Severity.Success);
        await _grid.ReloadServerData();
    }

    // ── Replace Approval ID ──────────────────────────────────────────────────
    private async Task OpenReplaceApprovalId()
    {
        var idsToUpdate = _selectedIds.ToList();
        var count = idsToUpdate.Count;

        var parameters = new DialogParameters { ["SelectedCount"] = count };
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ReplaceApprovalIdDialog>(
            "Replace Approval ID", parameters, options);
        var result = await dialog.Result;

        if (result.Canceled) return;

        int newEntryId = (int)result.Data!;

        bool? confirmed = await DialogService.ShowMessageBox(
            "CONFIRMATION DIALOG.",
            $"PLEASE CONFIRM TO PROCEED — this will replace the Approval ID on {count} record{(count == 1 ? "" : "s")} with {newEntryId}.",
            yesText: "Yes, Replace",
            cancelText: "Cancel");

        if (confirmed != true) return;

        await VendorPortalService.ReplaceEntryIdAsync(idsToUpdate, newEntryId);
        ClearSelection();
        Snackbar.Add($"Approval ID updated to {newEntryId} on {count} record(s).", Severity.Success);
        await _grid.ReloadServerData();
    }

    private Task OnFilterRemoved(string key)
    {
        ClearSelection();
        return Task.CompletedTask;
    }
}
