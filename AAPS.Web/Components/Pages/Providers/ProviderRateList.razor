@page "/providerrates"
@using AAPS.Application.Abstractions.Services
@using AAPS.Application.DTO
@using AAPS.Web.Components.Pages.Providers.Forms
@using AAPS.Web.Components.Shared
@inject IProviderRateService ProviderRateService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<GenericGrid @ref="_grid" TItem="ProviderRateDTO"
             Title="Provider Rates"
             Columns="@(new[] { "Actions", "ProviderFirstName", "ProviderLastName", "ServiceType", "District", "Language", "Rate", "EffectiveDate", "IsActive" })"
             GetData="ProviderRateService.GetPagedAsync"
             ExportHeaders="@(new[] { "FirstName", "LastName", "Service", "District", "Language", "Rate", "Effective Date", "Active" })"
             ExportMapper="@(r => new object?[] { r.ProviderFirstName, r.ProviderLastName, r.ServiceType, r.District, r.Language, r.Rate, r.EffectiveDate?.ToShortDateString(), r.IsActive })">

    <CustomActionContent>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => OpenEditDialog())"
                   Size="Size.Small"
                   Class="mr-4">
            Add Rate
        </MudButton>
    </CustomActionContent>

    <HeaderContent>
        <GridCell TItem="ProviderRateDTO" Column="Actions" IsHeader="true">Actions</GridCell>
        <GridCell TItem="ProviderRateDTO" Column="ProviderFirstName" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderFirstName" T="ProviderRateDTO">FirstName</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderRateDTO" Column="ProviderLastName" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderLastName" T="ProviderRateDTO">LastName</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderRateDTO" Column="ServiceType" IsHeader="true">
            <MudTableSortLabel SortLabel="ServiceType" T="ProviderRateDTO">Service</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderRateDTO" Column="District" IsHeader="true">
            <MudTableSortLabel SortLabel="District" T="ProviderRateDTO">District</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderRateDTO" Column="Language" IsHeader="true">
            <MudTableSortLabel SortLabel="Language" T="ProviderRateDTO">Language</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderRateDTO" Column="Rate" IsHeader="true">
            <MudTableSortLabel SortLabel="Rate" T="ProviderRateDTO">Rate</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderRateDTO" Column="EffectiveDate" IsHeader="true">
            <MudTableSortLabel SortLabel="EffectiveDate" T="ProviderRateDTO">Effective</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderRateDTO" Column="IsActive" IsHeader="true">
            <MudTableSortLabel SortLabel="IsActive" T="ProviderRateDTO">Active</MudTableSortLabel>
        </GridCell>
    </HeaderContent>

    <RowTemplate Context="rate">
        @* Action Buttons *@
        <GridCell TItem="ProviderRateDTO" Column="Actions">
            <div class="d-flex">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Size="Size.Small" Color="Color.Primary"
                               OnClick="@(() => OpenEditDialog(rate))" />

                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => OnDeleteClicked(rate))" />
            </div>
        </GridCell>

        <GridCell TItem="ProviderRateDTO" Column="ProviderFirstName">@rate.ProviderFirstName</GridCell>
        <GridCell TItem="ProviderRateDTO" Column="ProviderLastName">@rate.ProviderLastName</GridCell>
        <GridCell TItem="ProviderRateDTO" Column="ServiceType">@rate.ServiceType</GridCell>
        <GridCell TItem="ProviderRateDTO" Column="District">@rate.District</GridCell>
        <GridCell TItem="ProviderRateDTO" Column="Language">@rate.Language</GridCell>
        <GridCell TItem="ProviderRateDTO" Column="Rate">
            <MudText Color="Color.Success"><b>@rate.Rate?.ToString("C2")</b></MudText>
        </GridCell>
        <GridCell TItem="ProviderRateDTO" Column="EffectiveDate">
            <MudTooltip Text="@rate.EffectiveDate?.ToLongDateString()">
                <span>@rate.EffectiveDate?.ToString("MM/dd/yyyy")</span>
            </MudTooltip>
        </GridCell>
        <GridCell TItem="ProviderRateDTO" Column="IsActive">
            <MudChip T="string"
                     Color="@(rate.IsActive ? Color.Success : Color.Default)"
                     Size="Size.Small"
                     Variant="Variant.Text">
                @(rate.IsActive ? "Active" : "Inactive")
            </MudChip>
        </GridCell>
    </RowTemplate>
</GenericGrid>

@code {
    private GenericGrid<ProviderRateDTO> _grid = default!;
    private ProviderRateValidator _validator = new();

    // If 'rate' is passed, it's an EDIT. If it's null, it's an ADD.
    private async Task OpenEditDialog(ProviderRateDTO? rate = null)
    {
        ProviderRateDTO model;

        if (rate == null)
        {
            // 1. ADD SCENARIO: Start with a blank object
            model = new ProviderRateDTO { IsActive = true };
        }
        else
        {
            // 2. EDIT SCENARIO: Fetch the fresh data
            var fetched = await ProviderRateService.GetByIdAsync(rate.Id);
            if (fetched == null) return;
            model = fetched;
        }

        var isNew = rate == null;
        var parameters = new DialogParameters<EntityDialog<ProviderRateDTO>>();
        parameters.Add(x => x.Item, model);
        parameters.Add(x => x.Title, rate == null ? "Add New Rate" : "Edit Rate");
        parameters.Add(x => x.IsNew, isNew);
        parameters.Add(x => x.ValidateModel, async (ProviderRateDTO dto) =>
        {
            var result = await _validator.ValidateAsync(dto);
            return (IList<string>)result.Errors.Select(e => e.ErrorMessage).ToList();
        });
        // Keep passing ValidateValue for per-field display:
        parameters.Add(x => x.Validator, _validator.ValidateValue);
        parameters.Add(x => x.ChildContent, (ProviderRateDTO context) =>
            @<ProviderRateForm Model="context" IsAdd=isNew />);

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EntityDialog<ProviderRateDTO>>(" ", parameters, options);
        var result = await dialog.Result;

        // 3. THE SAVE LOGIC: Covers both Add and Edit
        if (result is not null && !result.Canceled && result.Data is ProviderRateDTO savedDto)
        {
            try
            {
                if (rate == null)
                {
                    // ADD: Create new rate
                    await ProviderRateService.CreateAsync(savedDto);
                    Snackbar.Add("Rate added successfully!", Severity.Success);
                }
                else
                {
                    // EDIT: Update existing rate
                    await ProviderRateService.UpdateAsync(savedDto.Id, savedDto);
                    Snackbar.Add("Rate updated successfully!", Severity.Success);
                }

                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error saving rate: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OnDeleteClicked(ProviderRateDTO rate)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning",
            $"Are you sure you want to delete this rate for {rate.ProviderFirstName} {rate.ProviderLastName}?",
            yesText: "Delete!", cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await ProviderRateService.DeleteAsync(rate.Id);
                Snackbar.Add("Rate deleted.", Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (InvalidOperationException ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
            catch (Exception)
            {
                Snackbar.Add("A system error occurred during deletion.", Severity.Error);
            }
        }
    }
}
