@using AAPS.Application.Abstractions.Services
@using AAPS.Application.DTO
@using AAPS.Web.Components.Pages.Files
@using MudBlazor.Extensions
@using System.Reflection
@using System.ComponentModel
@inject IProviderContactService ContactService
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IDialogService DialogService

<MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

    @* Tab 1: Basic Information *@
    <MudTabPanel Text="General Info" Icon="@Icons.Material.Filled.Person">
        <MudGrid>
            @if (IsVisible(nameof(Model.Id)))
            {
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Id"
                                  Label="Provider ID"
                                  ReadOnly="@IsLocked(nameof(Model.Id))"
                                  Variant="@(IsLocked(nameof(Model.Id)) ? Variant.Filled : Variant.Outlined)" />
                </MudItem>
            }

            @if (IsVisible(nameof(Model.FirstName)))
            {
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.FirstName"
                                  Label="First Name"
                                  Required
                                  ReadOnly="@IsLocked(nameof(Model.FirstName))" />
                </MudItem>
            }

            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Model.LastName"
                              Label="Last Name"
                              Validation="@(Validator)"
                              For="@(() => Model.LastName)"
                              Required />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Model.Ssn"
                              Label="SSN"
                              Variant="Variant.Text"
                              Mask="@(new PatternMask("000-00-0000"))"
                              Validation="@Validator"
                              For="@(() => Model.Ssn)"
                              Immediate="true"
                              Clearable="true"
                              Margin="Margin.None"
                              Required />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Model.TaxId" Label="Tax ID"
                              Validation="@(Validator)" For="@(() => Model.TaxId)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="Model.IsActive" T="bool?" Label="Status" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem T="bool?" Value="true">Active</MudSelectItem>
                    <MudSelectItem T="bool?" Value="false">Inactive</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Model.NpiNumber" Label="NPI Number" MaxLength="10" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* Tab 2: Contact & Address *@
    <MudTabPanel Text="Contact" Icon="@Icons.Material.Filled.ContactPhone">
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Model.Email" Label="Email"
                              Validation="@(Validator)" For="@(() => Model.Email)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudMask @bind-Value="Model.Phone" Label="Phone" Mask="@(new PatternMask("(000) 000-0000"))" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Model.Address" Label="Address" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="Model.City" Label="City" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="Model.State" Label="State" MaxLength="2" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="Model.Zipcode" Label="Zip" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* Tab 3: Compliance & Dates *@
    <MudTabPanel Text="Compliance" Icon="@Icons.Material.Filled.VerifiedUser">
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="Model.License1Expiration" Label="License 1 Exp"
                               Validation="@(Validator)" For="@(() => Model.License1Expiration)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="Model.W9Date" Label="W9 Date" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="Model.ContractDate" Label="Contract Date" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="Model.MedicalDate" Label="Medical Date" />
            </MudItem>
            <MudItem xs="12">
                <MudCheckBox @bind-Value="Model.HasPets" Label="Has Pets?" Color="Color.Primary" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* Tab 4: Provider Contact History *@
    <MudTabPanel Text="Contact Logs" Icon="@Icons.Material.Filled.History">
        <div class="pa-4">
            <MudTable Items="@contacts" Dense="true" Hover="true" Elevation="0" Context="contact">
                <ToolBarContent>
                    <MudText Typo="Typo.subtitle1">Communication Logs</MudText>
                    <MudSpacer />
                    <MudButton OnClick="AddContactRow" StartIcon="@Icons.Material.Filled.Add"
                               Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">
                        Add Log
                    </MudButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Notes</MudTh>
                    <MudTh Style="width:50px"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@contact.ContactDate?.ToString("MM/dd/yyyy")</MudTd>
                    <MudTd DataLabel="Notes">
                        @* Inline Edit for Notes *@
                        <MudTextField @bind-Value="contact.Notes" Margin="Margin.Dense" />
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error" OnClick="@(() => contacts.Remove(contact))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    </MudTabPanel>

    @* Tab 5: Provider Files *@
    <MudTabPanel Text="Files" Icon="@Icons.Material.Filled.Folder">
        @if (Model.Id == 0)
        {
            <MudAlert Severity="Severity.Info" Class="ma-4">
                Save the provider first before uploading files.
            </MudAlert>
        }
        else
        {
            @* Toolbar *@
            <div class="d-flex align-center justify-space-between mb-3">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    @_files.Count file(s)
                </MudText>
                <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="OnFilesUploaded" Multiple="true">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Upload"
                                   Size="Size.Small"
                                   Disabled="_filesLoading">
                            Upload Files
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
            </div>

            @* File list — fixed height, always scrollable *@
            <div style="height:320px; overflow-y:auto; border:1px solid var(--mud-palette-divider); border-radius:4px;">
                @if (_filesLoading)
                {
                    <div class="d-flex justify-center pa-4">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                    </div>
                }
                else if (_filesError != null)
                {
                    <MudAlert Severity="Severity.Warning">@_filesError</MudAlert>
                }
                else if (_files.Count == 0)
                {
                    <MudText Class="mud-text-secondary pa-4 d-flex justify-center" Typo="Typo.body2">
                        No files found for this provider.
                    </MudText>
                }
                else
                {
                    <MudTable Items="_files" Dense="true" Hover="true" Elevation="0" T="FileExplorerItem">
                        <HeaderContent>
                            <MudTh Style="width:36px; position:sticky; top:0; z-index:1; background:var(--mud-palette-surface);"></MudTh>
                            <MudTh Style="position:sticky; top:0; z-index:1; background:var(--mud-palette-surface);">File Name</MudTh>
                            <MudTh Style="width:160px; position:sticky; top:0; z-index:1; background:var(--mud-palette-surface);">Modified</MudTh>
                            <MudTh Style="width:80px; position:sticky; top:0; z-index:1; background:var(--mud-palette-surface);">Size</MudTh>
                            <MudTh Style="width:130px; position:sticky; top:0; z-index:1; background:var(--mud-palette-surface);"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudIcon Icon="@context.Icon" Size="Size.Small" Color="Color.Default" />
                            </MudTd>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                    @context.LastModified.ToString("MM/dd/yyyy hh:mm tt")
                                </MudText>
                            </MudTd>
                            <MudTd>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                    @context.SizeDisplay
                                </MudText>
                            </MudTd>
                            <MudTd>
                                <div class="d-flex gap-1">
                                    @if (context.IsPreviewable)
                                    {
                                        <MudTooltip Text="Preview">
                                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                           Size="Size.Small" Color="Color.Info"
                                                           OnClick="@(() => OpenPreview(context))" />
                                        </MudTooltip>
                                        <MudTooltip Text="Open in New Window">
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                           Size="Size.Small" Color="Color.Secondary"
                                                           OnClick="@(() => OpenInNewWindow(context))" />
                                        </MudTooltip>
                                    }
                                    <MudTooltip Text="Download">
                                        <MudIconButton Icon="@Icons.Material.Filled.Download"
                                                       Size="Size.Small" Color="Color.Primary"
                                                       OnClick="@(() => DownloadFile(context))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Size="Size.Small" Color="Color.Error"
                                                       OnClick="@(() => DeleteFile(context))" />
                                    </MudTooltip>
                                </div>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </div>
        }
    </MudTabPanel>
</MudTabs>

@code {
    [Parameter] public ProviderDTO Model { get; set; } = default!;

    public List<ProviderContactDTO> contacts = new();

    [CascadingParameter] public Func<object, string, Task<IEnumerable<string>>> Validator { get; set; } = default!;

    // Keyed injection for provider-specific file root (C:\AAPS\Provider Profiles)
    private IFileExplorerService FileExplorerService = default!;

    // ── Provider Files ─────────────────────────────────────
    private List<FileExplorerItem> _files = new();
    private bool _filesLoading = false;
    private string? _filesError;

    // Relative path is just the provider ID — maps to C:\AAPS\Provider Profiles\{id}
    private string ProviderFolderPath => Model.Id.ToString();

    protected override async Task OnInitializedAsync()
    {
        FileExplorerService = ServiceProvider.GetRequiredKeyedService<IFileExplorerService>("ProviderFiles");

        if (Model.Id > 0)
        {
            var result = await ContactService.GetByProviderIdAsync(Model.Id);
            contacts = result.ToList();
            await LoadProviderFiles();
        }
        else
        {
            contacts = new List<ProviderContactDTO>();
        }
    }

    private async Task LoadProviderFiles()
    {
        _filesLoading = true;
        _filesError = null;
        StateHasChanged();
        await Task.Delay(1);

        try
        {
            var result = FileExplorerService.GetContents(ProviderFolderPath);
            _files = result.Items.Where(i => !i.IsFolder).ToList();
        }
        catch (DirectoryNotFoundException)
        {
            // Folder doesn't exist yet — not an error, just no files uploaded yet
            _files = new();
        }
        catch (Exception ex)
        {
            _filesError = $"Could not load files: {ex.Message}";
        }
        finally
        {
            _filesLoading = false;
        }
    }

    private async Task OnFilesUploaded(IReadOnlyList<IBrowserFile> files)
    {
        if (files == null || files.Count == 0) return;

        // Create the provider's folder if it doesn't exist yet
        var folderPath = FileExplorerService.GetAbsolutePath(ProviderFolderPath);
        if (!Directory.Exists(folderPath))
            Directory.CreateDirectory(folderPath);

        const long maxFileSizeBytes = 100 * 1024 * 1024;
        var uploaded = 0;

        foreach (var file in files)
        {
            try
            {
                using var stream = file.OpenReadStream(maxFileSizeBytes);
                await FileExplorerService.SaveUploadedFileAsync(ProviderFolderPath, file.Name, stream);
                uploaded++;
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed: {file.Name} — {ex.Message}", Severity.Error);
            }
        }

        if (uploaded > 0)
            Snackbar.Add($"{uploaded} file(s) uploaded.", Severity.Success);

        await LoadProviderFiles();
    }

    private async Task OpenPreview(FileExplorerItem item)
    {
        var parameters = new DialogParameters
        {
            { "Item", item },
            { "FileExplorerService", FileExplorerService },
            { "BaseUrl", "/provider-files" }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseButton = true
        };

        await DialogService.ShowAsync<FilePreviewDialog>(item.Name, parameters, options);
    }

    private async Task OpenInNewWindow(FileExplorerItem item)
    {
        var url = $"/provider-files/preview?path={Uri.EscapeDataString(item.RelativePath)}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task DownloadFile(FileExplorerItem item)
    {
        var url = $"/provider-files/download?path={Uri.EscapeDataString(item.RelativePath)}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task DeleteFile(FileExplorerItem item)
    {
        try
        {
            FileExplorerService.DeleteFile(item.RelativePath);
            Snackbar.Add($"Deleted \"{item.Name}\".", Severity.Success);
            await LoadProviderFiles();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    private void AddContactRow()
    {
        contacts.Insert(0, new ProviderContactDTO
        {
            ProviderId = Model.Id,
            ContactDate = DateTime.Now
        });
    }

    private bool IsVisible(string propName)
    {
        if (string.IsNullOrEmpty(propName)) return true;
        var prop = typeof(ProviderDTO).GetProperty(propName);
        var attr = prop?.GetCustomAttribute<BrowsableAttribute>();
        return attr?.Browsable ?? true;
    }
    private bool IsLocked(string propName)
    {
        var prop = typeof(ProviderDTO).GetProperty(propName);
        var attr = prop?.GetCustomAttribute<ReadOnlyAttribute>();
        return attr?.IsReadOnly ?? false;
    }

    public List<ProviderContactDTO> GetUpdatedContacts() => contacts;
}
