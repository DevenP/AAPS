@page "/providerbilling"
@using AAPS.Application.Abstractions.Services
@using AAPS.Application.Common.Extensions
@using AAPS.Application.DTO
@using AAPS.Web.Components.Shared
@using System.Reflection
@inject ISesiService SesiService

<GenericGrid TItem="ProviderBillingDTO"
             @ref="_grid"
             Title="Provider Billing"
             DefaultSortLabel="DateOfService"
             Columns="@(new[] { "StudentId", "StudentLastName", "ProviderLastName", "EntryId", "DateOfService", "StartTime", "EndTime", "Duration", "ServiceType", "GDistrict", "BilledRate", "BilledAmount", "BilledDate", "BilledPaidDate", "ProviderRate", "ProviderAmount", "ProviderPaidDate", "Voucher" })"
             GetData="SesiService.GetProviderBillingPagedAsync"
             ExportHeaders="@(new[] { DN(nameof(ProviderBillingDTO.StudentId)), DN(nameof(ProviderBillingDTO.StudentLastName)), DN(nameof(ProviderBillingDTO.ProviderLastName)), DN(nameof(ProviderBillingDTO.EntryId)), DN(nameof(ProviderBillingDTO.DateOfService)), DN(nameof(ProviderBillingDTO.StartTime)), DN(nameof(ProviderBillingDTO.EndTime)), DN(nameof(ProviderBillingDTO.Duration)), DN(nameof(ProviderBillingDTO.ServiceType)), DN(nameof(ProviderBillingDTO.GDistrict)), DN(nameof(ProviderBillingDTO.BilledRate)), DN(nameof(ProviderBillingDTO.BilledAmount)), DN(nameof(ProviderBillingDTO.BilledDate)), DN(nameof(ProviderBillingDTO.BilledPaidDate)), DN(nameof(ProviderBillingDTO.ProviderRate)), DN(nameof(ProviderBillingDTO.ProviderAmount)), DN(nameof(ProviderBillingDTO.ProviderPaidDate)), DN(nameof(ProviderBillingDTO.Voucher)) })"
             ExportMapper="@(s => new object?[] { s.StudentId, $"{s.StudentLastName}, {s.StudentFirstName}", $"{s.ProviderLastName}, {s.ProviderFirstName}", s.EntryId, s.DateOfService?.ToString("MM/dd/yyyy"), s.StartTime, s.EndTime, s.Duration, s.ServiceType, s.GDistrict, s.BilledRate, s.BilledAmount, s.BilledDate?.ToString("MM/dd/yyyy"), s.BilledPaidDate?.ToString("MM/dd/yyyy"), s.ProviderRate, s.ProviderAmount, s.ProviderPaidDate?.ToString("MM/dd/yyyy"), s.Voucher })">

    <HeaderContent>
        <GridCell TItem="ProviderBillingDTO" Column="StudentId" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentId" T="ProviderBillingDTO">@_grid?.GetDisplayName("StudentId")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="StudentLastName" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentLastName" T="ProviderBillingDTO">@_grid?.GetDisplayName("StudentLastName")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="ProviderLastName" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderLastName" T="ProviderBillingDTO">@_grid?.GetDisplayName("ProviderLastName")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="EntryId" IsHeader="true">
            <MudTableSortLabel SortLabel="EntryId" T="ProviderBillingDTO">@_grid?.GetDisplayName("EntryId")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="DateOfService" IsHeader="true">
            <MudTableSortLabel SortLabel="DateOfService" T="ProviderBillingDTO">@_grid?.GetDisplayName("DateOfService")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="StartTime" IsHeader="true">
            <MudTableSortLabel SortLabel="StartTime" T="ProviderBillingDTO">@_grid?.GetDisplayName("StartTime")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="EndTime" IsHeader="true">
            <MudTableSortLabel SortLabel="EndTime" T="ProviderBillingDTO">@_grid?.GetDisplayName("EndTime")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="Duration" IsHeader="true">
            <MudTableSortLabel SortLabel="Duration" T="ProviderBillingDTO">@_grid?.GetDisplayName("Duration")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="ServiceType" IsHeader="true">
            <MudTableSortLabel SortLabel="ServiceType" T="ProviderBillingDTO">@_grid?.GetDisplayName("ServiceType")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="GDistrict" IsHeader="true">
            <MudTableSortLabel SortLabel="GDistrict" T="ProviderBillingDTO">@_grid?.GetDisplayName("GDistrict")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="BilledRate" IsHeader="true">
            <MudTableSortLabel SortLabel="BilledRate" T="ProviderBillingDTO">@_grid?.GetDisplayName("BilledRate")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="BilledAmount" IsHeader="true">
            <MudTableSortLabel SortLabel="BilledAmount" T="ProviderBillingDTO">@_grid?.GetDisplayName("BilledAmount")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="BilledDate" IsHeader="true">
            <MudTableSortLabel SortLabel="BilledDate" T="ProviderBillingDTO">@_grid?.GetDisplayName("BilledDate")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="BilledPaidDate" IsHeader="true">
            <MudTableSortLabel SortLabel="BilledPaidDate" T="ProviderBillingDTO">@_grid?.GetDisplayName("BilledPaidDate")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="ProviderRate" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderRate" T="ProviderBillingDTO">@_grid?.GetDisplayName("ProviderRate")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="ProviderAmount" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderAmount" T="ProviderBillingDTO">@_grid?.GetDisplayName("ProviderAmount")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="ProviderPaidDate" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderPaidDate" T="ProviderBillingDTO">@_grid?.GetDisplayName("ProviderPaidDate")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="Voucher" IsHeader="true">
            <MudTableSortLabel SortLabel="Voucher" T="ProviderBillingDTO">@_grid?.GetDisplayName("Voucher")</MudTableSortLabel>
        </GridCell>
    </HeaderContent>

    <RowTemplate Context="s">
        <GridCell TItem="ProviderBillingDTO" Column="StudentId">@s.StudentId</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="StudentLastName">@s.StudentLastName, @s.StudentFirstName</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="ProviderLastName">@s.ProviderLastName, @s.ProviderFirstName</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="EntryId">@s.EntryId</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="DateOfService">
            <MudTooltip Text="@s.DateOfService?.ToLongDateString()">
                <span>@s.DateOfService?.ToString("MM/dd/yyyy")</span>
            </MudTooltip>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="StartTime">@s.StartTime</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="EndTime">@s.EndTime</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="Duration">@s.Duration</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="ServiceType">@s.ServiceType</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="GDistrict">@s.GDistrict</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="BilledRate">@s.BilledRate?.ToString("C2")</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="BilledAmount">@s.BilledAmount?.ToString("C2")</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="BilledDate">
            <MudChip T="string" Color="@(s.BilledDate != null ? Color.Success : Color.Default)" Size="Size.Small" Variant="Variant.Text">
                @(s.BilledDate?.ToString("MM/dd/yyyy") ?? "Unbilled")
            </MudChip>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="BilledPaidDate">
            <MudChip T="string" Color="@(s.BilledPaidDate != null ? Color.Success : Color.Default)" Size="Size.Small" Variant="Variant.Text">
                @(s.BilledPaidDate?.ToString("MM/dd/yyyy") ?? "Unpaid")
            </MudChip>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="ProviderRate">@s.ProviderRate?.ToString("C2")</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="ProviderAmount">@s.ProviderAmount?.ToString("C2")</GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="ProviderPaidDate">
            <MudChip T="string" Color="@(s.ProviderPaidDate != null ? Color.Success : Color.Default)" Size="Size.Small" Variant="Variant.Text">
                @(s.ProviderPaidDate?.ToString("MM/dd/yyyy") ?? "Unpaid")
            </MudChip>
        </GridCell>
        <GridCell TItem="ProviderBillingDTO" Column="Voucher">@s.Voucher</GridCell>
    </RowTemplate>
</GenericGrid>

@code {
    private GenericGrid<ProviderBillingDTO> _grid = default!;

    private static string DN(string prop) =>
        typeof(ProviderBillingDTO).GetProperty(prop)?.GetDisplayName() ?? prop;
}
