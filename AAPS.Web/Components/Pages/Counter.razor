@page "/counter"

<PageTitle>Counter</PageTitle>

<h2 class="text-xl font-semibold mb-4">Records</h2>

<div class="space-y-3 max-w-xl">
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Global search</label>
        <input class="w-full border rounded px-3 py-2"/>
    </div>

    <div class="flex gap-3">
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Page</label>
            <input class="border rounded px-3 py-2 w-24"
                   type="number" />
        </div>

        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Page size</label>
            <select class="border rounded px-3 py-2">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>
    </div>
</div>

@code {


    protected override void OnInitialized()
    {
        
    }
}
