@page "/operations"
@using AAPS.Application.Abstractions.Services
@using AAPS.Application.Common.Paging
@using AAPS.Application.Common.Extensions
@using AAPS.Application.DTO
@using AAPS.Web.Components.Pages.Operations.Forms
@using AAPS.Web.Components.Shared
@using System.Reflection
@inject ISesiService SesiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<OperationsList> Logger

<div style="position:sticky;top:0;z-index:200;background:var(--mud-palette-surface);border-bottom:1px solid var(--mud-palette-divider);padding:5px 16px;display:flex;flex-wrap:wrap;gap:16px;align-items:center;">
    <MudText Typo="Typo.caption" Style="font-weight:700;opacity:0.5;letter-spacing:.05em;">ALERT LEGEND</MudText>
    <span style="display:inline-flex;align-items:center;gap:4px;"><MudIcon Icon="@Icons.Material.Filled.AssignmentLate" Color="Color.Error"   Size="Size.Small" /><MudText Typo="Typo.caption">Missing Approval</MudText></span>
    <span style="display:inline-flex;align-items:center;gap:4px;"><MudIcon Icon="@Icons.Material.Filled.PersonOff"       Color="Color.Error"   Size="Size.Small" /><MudText Typo="Typo.caption">Unassigned Provider</MudText></span>
    <span style="display:inline-flex;align-items:center;gap:4px;"><MudIcon Icon="@Icons.Material.Filled.EventRepeat"     Color="Color.Error"   Size="Size.Small" /><MudText Typo="Typo.caption">Overlap Service</MudText></span>
    <span style="display:inline-flex;align-items:center;gap:4px;"><MudIcon Icon="@Icons.Material.Filled.LibraryAddCheck" Color="Color.Error"   Size="Size.Small" /><MudText Typo="Typo.caption">Over Mandate</MudText></span>
    <span style="display:inline-flex;align-items:center;gap:4px;"><MudIcon Icon="@Icons.Material.Filled.TimerOff"        Color="Color.Warning" Size="Size.Small" /><MudText Typo="Typo.caption">Over Duration</MudText></span>
    <span style="display:inline-flex;align-items:center;gap:4px;"><MudIcon Icon="@Icons.Material.Filled.Groups"          Color="Color.Info"    Size="Size.Small" /><MudText Typo="Typo.caption">Under Group Size</MudText></span>
    <span style="display:inline-flex;align-items:center;gap:4px;"><MudIcon Icon="@Icons.Material.Filled.MoneyOff"        Color="Color.Warning" Size="Size.Small" /><MudText Typo="Typo.caption">Missing Billing Rate</MudText></span>
    <span style="display:inline-flex;align-items:center;gap:4px;"><MudIcon Icon="@Icons.Material.Filled.MoneyOff"        Color="Color.Warning" Size="Size.Small" /><MudText Typo="Typo.caption">Missing Provider Rate</MudText></span>
    <span style="display:inline-flex;align-items:center;gap:4px;"><MudIcon Icon="@Icons.Material.Filled.LinkOff"         Color="Color.Info"    Size="Size.Small" /><MudText Typo="Typo.caption">Missing Assignment ID</MudText></span>
</div>

<GenericGrid TItem="OperationsDTO"
             @ref="_grid"
             Title="Operations"
             Columns="@(new[] { "Checkbox", "Actions", "Alerts", "DateOfService", "StartTime", "EndTime", "ProviderLastName", "GDistrict", "StudentId", "StudentLastName", "ServiceType", "LanguageProvided", "ActualSize", "Duration", "AssignmentClaimed", "EntryId", "ProviderPaidDate", "BilledDate", "Voucher", "AssignId" })"
             DefaultSortLabel="DateOfService"
             GetData="SesiService.GetOperationsPagedAsync"
             ExportHeaders="@(new[] { DN(nameof(OperationsDTO.DateOfService)), DN(nameof(OperationsDTO.StartTime)), DN(nameof(OperationsDTO.EndTime)), DN(nameof(OperationsDTO.ProviderLastName)), DN(nameof(OperationsDTO.GDistrict)), DN(nameof(OperationsDTO.StudentId)), DN(nameof(OperationsDTO.StudentLastName)), DN(nameof(OperationsDTO.ServiceType)), DN(nameof(OperationsDTO.LanguageProvided)), DN(nameof(OperationsDTO.ActualSize)), DN(nameof(OperationsDTO.Duration)), DN(nameof(OperationsDTO.AssignmentClaimed)), DN(nameof(OperationsDTO.EntryId)), DN(nameof(OperationsDTO.ProviderPaidDate)), DN(nameof(OperationsDTO.BilledDate)), DN(nameof(OperationsDTO.Voucher)), DN(nameof(OperationsDTO.AssignId)) })"
             ExportMapper="@(op => new object?[] { op.DateOfService?.ToString("MM/dd/yyyy"), op.StartTime, op.EndTime, CombineName(op.ProviderLastName, op.ProviderFirstName), op.GDistrict, op.StudentId, CombineName(op.StudentLastName, op.StudentFirstName), op.ServiceType, op.LanguageProvided, op.ActualSize, op.Duration, op.AssignmentClaimed, op.EntryId, op.ProviderPaidDate?.ToString("MM/dd/yyyy"), op.BilledDate?.ToString("MM/dd/yyyy"), op.Voucher, op.AssignId })"
             OnFilterRemoved="OnFilterRemoved">

    <CustomActionContent>
        @if (_selectedIds.Count > 0)
        {
            <MudText Typo="Typo.caption" Class="mr-2 align-self-center">
                @_selectedIds.Count selected
            </MudText>

            @if (_busy)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }

            <MudMenu Label="Actions"
                     Variant="Variant.Filled"
                     Color="Color.Primary"
                     EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                     Size="Size.Small"
                     Class="mr-2"
                     Disabled="_busy">
                <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                             OnClick="OpenBulkEditDialog">
                    Edit Fields
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.LinkOff"
                             OnClick="ConfirmUnlinkApprovalId">
                    Unlink Approval ID
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.PersonOff"
                             IconColor="Color.Error"
                             OnClick="ConfirmDeleteProviderBilling">
                    <MudText Color="Color.Error">Delete Provider Billing</MudText>
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.CheckCircle"
                             OnClick="ConfirmMarkVoucherBalancePaid">
                    Mark Voucher Balance Paid
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.RemoveCircleOutline"
                             OnClick="ConfirmUnmarkVoucherBalancePaid">
                    Unmark Voucher Balance Paid
                </MudMenuItem>
            </MudMenu>

            <MudIconButton Icon="@Icons.Material.Filled.Deselect"
                           Title="Clear selection"
                           Size="Size.Small"
                           OnClick="ClearSelection" />
        }
    </CustomActionContent>

    <HeaderContent>
        <MudTh Style="width:40px; padding: 0 8px;">
            <MudCheckBox T="bool"
                         Value="_allSelected"
                         ValueChanged="ToggleSelectAll"
                         Color="Color.Primary"
                         Size="Size.Small" />
        </MudTh>
        <MudTh Style="width:80px; padding: 0 8px;">Actions</MudTh>
        <GridCell TItem="OperationsDTO" Column="Alerts" IsHeader="true">Alerts</GridCell>
        <GridCell TItem="OperationsDTO" Column="DateOfService" IsHeader="true">
            <MudTableSortLabel SortLabel="DateOfService" T="OperationsDTO">@_grid?.GetDisplayName("DateOfService")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="StartTime" IsHeader="true">
            <MudTableSortLabel SortLabel="StartTime" T="OperationsDTO">@_grid?.GetDisplayName("StartTime")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="EndTime" IsHeader="true">
            <MudTableSortLabel SortLabel="EndTime" T="OperationsDTO">@_grid?.GetDisplayName("EndTime")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="ProviderLastName" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderLastName" T="OperationsDTO">@_grid?.GetDisplayName("ProviderLastName")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="GDistrict" IsHeader="true">
            <MudTableSortLabel SortLabel="GDistrict" T="OperationsDTO">@_grid?.GetDisplayName("GDistrict")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="StudentId" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentId" T="OperationsDTO">@_grid?.GetDisplayName("StudentId")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="StudentLastName" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentLastName" T="OperationsDTO">@_grid?.GetDisplayName("StudentLastName")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="ServiceType" IsHeader="true">
            <MudTableSortLabel SortLabel="ServiceType" T="OperationsDTO">@_grid?.GetDisplayName("ServiceType")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="LanguageProvided" IsHeader="true">
            <MudTableSortLabel SortLabel="LanguageProvided" T="OperationsDTO">@_grid?.GetDisplayName("LanguageProvided")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="ActualSize" IsHeader="true">
            <MudTableSortLabel SortLabel="ActualSize" T="OperationsDTO">@_grid?.GetDisplayName("ActualSize")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="Duration" IsHeader="true">
            <MudTableSortLabel SortLabel="Duration" T="OperationsDTO">@_grid?.GetDisplayName("Duration")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="AssignmentClaimed" IsHeader="true">
            <MudTableSortLabel SortLabel="AssignmentClaimed" T="OperationsDTO">@_grid?.GetDisplayName("AssignmentClaimed")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="EntryId" IsHeader="true">
            <MudTableSortLabel SortLabel="EntryId" T="OperationsDTO">@_grid?.GetDisplayName("EntryId")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="ProviderPaidDate" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderPaidDate" T="OperationsDTO">@_grid?.GetDisplayName("ProviderPaidDate")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="BilledDate" IsHeader="true">
            <MudTableSortLabel SortLabel="BilledDate" T="OperationsDTO">@_grid?.GetDisplayName("BilledDate")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="Voucher" IsHeader="true">
            <MudTableSortLabel SortLabel="Voucher" T="OperationsDTO">@_grid?.GetDisplayName("Voucher")</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="AssignId" IsHeader="true">
            <MudTableSortLabel SortLabel="AssignId" T="OperationsDTO">@_grid?.GetDisplayName("AssignId")</MudTableSortLabel>
        </GridCell>
    </HeaderContent>

    <RowTemplate Context="op">
        <MudTd Style="width:40px; padding: 0 8px;" @onmousedown="@(e => _shiftHeld = e.ShiftKey)">
            <MudCheckBox T="bool"
                         Value="_selectedIds.Contains(op.Id)"
                         ValueChanged="@(v => ToggleRow(op.Id, v, _grid.CurrentPageItems.IndexOf(op)))"
                         Color="Color.Primary"
                         Size="Size.Small" />
        </MudTd>

        <MudTd Style="width:80px; padding: 0 4px;">
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Size="Size.Small"
                           Color="Color.Primary"
                           Title="Edit Record"
                           OnClick="@(() => OpenSingleEditDialog(op))" />
            <MudIconButton Icon="@Icons.Material.Filled.AssignmentInd"
                           Size="Size.Small"
                           Color="Color.Secondary"
                           Title="OSIS Approvals"
                           OnClick="@(() => OpenOsisDialog(op))" />
        </MudTd>

        @* Combined Alert Icons Column *@
        <GridCell TItem="OperationsDTO" Column="Alerts">
            <div class="d-flex gap-1">
                @if (op.MandateFlag)   { <MudTooltip Text="Missing Approval">      <MudIcon Icon="@Icons.Material.Filled.AssignmentLate" Color="Color.Error"   Size="Size.Small" /></MudTooltip> }
                @if (op.ProviderFlag)  { <MudTooltip Text="Unassigned Provider">   <MudIcon Icon="@Icons.Material.Filled.PersonOff"       Color="Color.Error"   Size="Size.Small" /></MudTooltip> }
                @if (op.IsOverlap)     { <MudTooltip Text="Overlap Service">       <MudIcon Icon="@Icons.Material.Filled.EventRepeat"     Color="Color.Error"   Size="Size.Small" /></MudTooltip> }
                @if (op.IsOverMandate) { <MudTooltip Text="Over Mandate Service">  <MudIcon Icon="@Icons.Material.Filled.LibraryAddCheck" Color="Color.Error"   Size="Size.Small" /></MudTooltip> }
                @if (op.IsOverDuration){ <MudTooltip Text="Over Duration">         <MudIcon Icon="@Icons.Material.Filled.TimerOff"        Color="Color.Warning" Size="Size.Small" /></MudTooltip> }
                @if (op.IsUnderGroup)  { <MudTooltip Text="Under Group Size">      <MudIcon Icon="@Icons.Material.Filled.Groups"          Color="Color.Info"    Size="Size.Small" /></MudTooltip> }
                @if (op.BRateFlag)     { <MudTooltip Text="Missing Billing Rate">  <MudIcon Icon="@Icons.Material.Filled.MoneyOff"        Color="Color.Warning" Size="Size.Small" /></MudTooltip> }
                @if (op.PRateFlag)     { <MudTooltip Text="Missing Provider Rate"> <MudIcon Icon="@Icons.Material.Filled.MoneyOff"        Color="Color.Warning" Size="Size.Small" /></MudTooltip> }
                @if (op.AssignFlag)    { <MudTooltip Text="Missing Assignment Id"> <MudIcon Icon="@Icons.Material.Filled.LinkOff"         Color="Color.Info"    Size="Size.Small" /></MudTooltip> }
            </div>
        </GridCell>

        <GridCell TItem="OperationsDTO" Column="DateOfService">
            <MudTooltip Text="@op.DateOfService?.ToLongDateString()">
                <span>@op.DateOfService?.ToString("MM/dd/yyyy")</span>
            </MudTooltip>
        </GridCell>
        <GridCell TItem="OperationsDTO" Column="StartTime">@op.StartTime</GridCell>
        <GridCell TItem="OperationsDTO" Column="EndTime">@op.EndTime</GridCell>
        <GridCell TItem="OperationsDTO" Column="ProviderLastName">@CombineName(op.ProviderLastName, op.ProviderFirstName)</GridCell>
        <GridCell TItem="OperationsDTO" Column="GDistrict">@op.GDistrict</GridCell>
        <GridCell TItem="OperationsDTO" Column="StudentId">@op.StudentId</GridCell>
        <GridCell TItem="OperationsDTO" Column="StudentLastName">@CombineName(op.StudentLastName, op.StudentFirstName)</GridCell>
        <GridCell TItem="OperationsDTO" Column="ServiceType">@op.ServiceType</GridCell>
        <GridCell TItem="OperationsDTO" Column="LanguageProvided">@op.LanguageProvided</GridCell>
        <GridCell TItem="OperationsDTO" Column="ActualSize">@op.ActualSize</GridCell>
        <GridCell TItem="OperationsDTO" Column="Duration">@op.Duration</GridCell>
        <GridCell TItem="OperationsDTO" Column="AssignmentClaimed">@op.AssignmentClaimed</GridCell>
        <GridCell TItem="OperationsDTO" Column="EntryId">@op.EntryId</GridCell>
        <GridCell TItem="OperationsDTO" Column="ProviderPaidDate">@op.ProviderPaidDate?.ToString("MM/dd/yyyy")</GridCell>
        <GridCell TItem="OperationsDTO" Column="BilledDate">@op.BilledDate?.ToString("MM/dd/yyyy")</GridCell>
        <GridCell TItem="OperationsDTO" Column="Voucher">@op.Voucher</GridCell>
        <GridCell TItem="OperationsDTO" Column="AssignId">
            <span style="font-family: monospace;">@op.AssignId</span>
        </GridCell>
    </RowTemplate>
</GenericGrid>

@code {
    private GenericGrid<OperationsDTO> _grid = default!;

    private static string DN(string prop) =>
        typeof(OperationsDTO).GetProperty(prop)?.GetDisplayName() ?? prop;

    private static string CombineName(string? last, string? first) =>
        string.IsNullOrEmpty(first) ? last ?? "" : $"{last}, {first}";

    // ── Busy state ────────────────────────────────────────────────────────────
    private bool _busy = false;

    // ── Selection state ──────────────────────────────────────────────────────
    private HashSet<int> _selectedIds = new();
    private bool _allSelected = false;
    private bool _shiftHeld = false;
    private int _lastClickedIndex = -1;

    private void ToggleRow(int id, bool selected, int index)
    {
        if (_shiftHeld && _lastClickedIndex >= 0)
        {
            var items = _grid.CurrentPageItems;
            var from = Math.Min(_lastClickedIndex, index);
            var to = Math.Max(_lastClickedIndex, index);
            for (int i = from; i <= to; i++)
            {
                if (selected) _selectedIds.Add(items[i].Id);
                else _selectedIds.Remove(items[i].Id);
            }
        }
        else
        {
            if (selected) _selectedIds.Add(id);
            else _selectedIds.Remove(id);
        }
        _lastClickedIndex = index;
        _allSelected = false;
    }

    private async Task ToggleSelectAll(bool selected)
    {
        _allSelected = selected;
        if (!selected)
        {
            _selectedIds.Clear();
            return;
        }

        var request = new PagedRequest(_grid.Search, _grid.ColumnFilters, PageSize: -1);
        var result = await SesiService.GetOperationsPagedAsync(request);
        _selectedIds = result.Items.Select(i => i.Id).ToHashSet();
    }

    private void ClearSelection()
    {
        _selectedIds.Clear();
        _allSelected = false;
        _lastClickedIndex = -1;
    }

    private Task OnFilterRemoved(string key)
    {
        ClearSelection();
        return Task.CompletedTask;
    }

    // ── OSIS Approvals ───────────────────────────────────────────────────────
    private async Task OpenOsisDialog(OperationsDTO op)
    {
        var parameters = new DialogParameters<OsisApprovalsDialog>
        {
            { x => x.StudentId,   op.StudentId ?? "" },
            { x => x.StudentName, $"{op.StudentLastName}, {op.StudentFirstName}" }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        await DialogService.ShowAsync<OsisApprovalsDialog>(
            $"OSIS Approvals — {op.StudentId} · {op.StudentLastName}, {op.StudentFirstName}",
            parameters, options);
    }

    // ── Single-row edit ──────────────────────────────────────────────────────
    private async Task OpenSingleEditDialog(OperationsDTO item)
    {
        var parameters = new DialogParameters<OperationEditDialog>
        {
            { x => x.Item, item },
            { x => x.IsBulk, false },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<OperationEditDialog>("Edit Record", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;
        if (result.Data is OperationEditDTO dto)
            await ApplyEdit([item.Id], dto);
    }

    // ── Bulk edit ────────────────────────────────────────────────────────────
    private async Task OpenBulkEditDialog()
    {
        var ids = _selectedIds.ToList();
        var parameters = new DialogParameters<OperationEditDialog>
        {
            { x => x.IsBulk, true },
            { x => x.SelectedCount, ids.Count },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<OperationEditDialog>("Edit Fields", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;
        if (result.Data is OperationEditDTO dto)
            await ApplyEdit(ids, dto);
    }

    private async Task ApplyEdit(List<int> ids, OperationEditDTO dto)
    {
        _busy = true;
        StateHasChanged();
        try
        {
            await SesiService.BulkUpdateAsync(ids, dto);
            Snackbar.Add($"{ids.Count} record(s) updated.", Severity.Success);
            ClearSelection();
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error bulk-updating operations records");
            Snackbar.Add($"Error saving: {ex.Message.Split('\n')[0].Trim()}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    // ── Unlink Approval ID ───────────────────────────────────────────────────
    private async Task ConfirmUnlinkApprovalId()
    {
        var ids = _selectedIds.ToList();
        var count = ids.Count;

        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "CONFIRMATION DIALOG.",
            $"PLEASE CONFIRM TO PROCEED — this will unlink the Approval ID on {count} record{(count == 1 ? "" : "s")}.",
            yesText: "Yes, Unlink",
            cancelText: "Cancel");

        if (confirmed != true) return;

        _busy = true;
        StateHasChanged();
        try
        {
            await SesiService.BulkUnlinkApprovalIdAsync(ids);
            ClearSelection();
            Snackbar.Add($"Approval ID unlinked on {count} record(s).", Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error unlinking approval IDs");
            Snackbar.Add($"Error: {ex.Message.Split('\n')[0].Trim()}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    // ── Mark / Unmark Voucher Balance Paid ───────────────────────────────────
    private async Task ConfirmMarkVoucherBalancePaid()
    {
        var ids = _selectedIds.ToList();
        var count = ids.Count;

        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "CONFIRMATION DIALOG.",
            $"PLEASE CONFIRM TO PROCEED — this will mark Voucher Balance Paid on {count} record{(count == 1 ? "" : "s")} (only where not already set).",
            yesText: "Yes, Mark",
            cancelText: "Cancel");

        if (confirmed != true) return;

        _busy = true;
        StateHasChanged();
        try
        {
            await SesiService.BulkMarkVoucherBalancePaidAsync(ids);
            ClearSelection();
            Snackbar.Add($"Voucher Balance Paid marked on {count} record(s).", Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error marking voucher balance paid");
            Snackbar.Add($"Error: {ex.Message.Split('\n')[0].Trim()}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ConfirmUnmarkVoucherBalancePaid()
    {
        var ids = _selectedIds.ToList();
        var count = ids.Count;

        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "CONFIRMATION DIALOG.",
            $"PLEASE CONFIRM TO PROCEED — this will clear Voucher Balance Paid on {count} record{(count == 1 ? "" : "s")} (only where VoucherAmount differs from billed amount).",
            yesText: "Yes, Unmark",
            cancelText: "Cancel");

        if (confirmed != true) return;

        _busy = true;
        StateHasChanged();
        try
        {
            await SesiService.BulkUnmarkVoucherBalancePaidAsync(ids);
            ClearSelection();
            Snackbar.Add($"Voucher Balance Paid cleared on {count} record(s).", Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error unmarking voucher balance paid");
            Snackbar.Add($"Error: {ex.Message.Split('\n')[0].Trim()}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    // ── Delete Provider Billing ──────────────────────────────────────────────
    private async Task ConfirmDeleteProviderBilling()
    {
        var ids = _selectedIds.ToList();
        var count = ids.Count;

        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "CONFIRMATION DIALOG.",
            $"PLEASE CONFIRM TO PROCEED — this will permanently delete {count} selected record{(count == 1 ? "" : "s")} that have no Approval ID linked. Records with an Approval ID will be skipped.",
            yesText: "Yes, Delete",
            cancelText: "Cancel");

        if (confirmed != true) return;

        _busy = true;
        StateHasChanged();
        try
        {
            var deleted = await SesiService.BulkDeleteProviderBillingAsync(ids);
            ClearSelection();
            var skipped = count - deleted;

            if (deleted > 0)
                Snackbar.Add($"{deleted} record{(deleted == 1 ? "" : "s")} deleted.", Severity.Success);

            if (skipped > 0)
                Snackbar.Add($"{skipped} record{(skipped == 1 ? " was" : "s were")} skipped — records with an Approval ID cannot be deleted.", Severity.Warning);

            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting provider billing");
            Snackbar.Add($"Error: {ex.Message.Split('\n')[0].Trim()}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
