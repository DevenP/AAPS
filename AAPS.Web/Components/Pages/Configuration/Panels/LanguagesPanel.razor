@using AAPS.Application.Abstractions.Services
@using AAPS.Application.DTO
@using AAPS.Web.Components.Pages.Configuration.Forms
@using AAPS.Web.Components.Shared
@inject ILanguageService LanguageService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<GenericGrid @ref="_grid" TItem="LanguageDTO"
             Title="Languages"
             DefaultSortLabel="Name"
             Columns="@(new[] { "Actions", "Name", "Code" })"
             GetData="LanguageService.GetPagedAsync"
             ExportHeaders="@(new[] { "Language", "Code" })"
             ExportMapper="@(l => new object?[] { l.Name, l.Code })">

    <CustomActionContent>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => OpenEditDialog())"
                   Size="Size.Small"
                   Class="mr-4">
            Add Language
        </MudButton>
    </CustomActionContent>

    <HeaderContent>
        <GridCell TItem="LanguageDTO" Column="Actions" IsHeader="true">Actions</GridCell>
        <GridCell TItem="LanguageDTO" Column="Name" IsHeader="true">
            <MudTableSortLabel SortLabel="Name" T="LanguageDTO">Language</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="LanguageDTO" Column="Code" IsHeader="true">
            <MudTableSortLabel SortLabel="Code" T="LanguageDTO">Code</MudTableSortLabel>
        </GridCell>
    </HeaderContent>

    <RowTemplate Context="l">
        <GridCell TItem="LanguageDTO" Column="Actions">
            <div class="d-flex">
                <MudTooltip Text="Edit Language">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => OpenEditDialog(l))" />
                </MudTooltip>
                <MudTooltip Text="Delete Language">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => OnDeleteClicked(l))" />
                </MudTooltip>
            </div>
        </GridCell>
        <GridCell TItem="LanguageDTO" Column="Name">@l.Name</GridCell>
        <GridCell TItem="LanguageDTO" Column="Code">@l.Code</GridCell>
    </RowTemplate>

</GenericGrid>

@code {
    private GenericGrid<LanguageDTO>? _grid;
    private LanguageValidator _validator = new();

    private async Task OpenEditDialog(LanguageDTO? language = null)
    {
        LanguageDTO model;

        if (language == null)
        {
            model = new LanguageDTO();
        }
        else
        {
            var fresh = await LanguageService.GetByIdAsync(language.Id);
            if (fresh == null) return;
            model = fresh;
        }

        var parameters = new DialogParameters<EntityDialog<LanguageDTO>>();
        parameters.Add(x => x.Item, model);
        parameters.Add(x => x.Title, language == null ? "Add Language" : "Edit Language");
        parameters.Add(x => x.IsNew, language == null);
        parameters.Add(x => x.Validator, _validator.ValidateValue);
        parameters.Add(x => x.ValidateModel, async (LanguageDTO dto) =>
        {
            var result = await _validator.ValidateAsync(dto);
            return (IList<string>)result.Errors.Select(e => e.ErrorMessage).ToList();
        });
        parameters.Add(x => x.ChildContent, (LanguageDTO context) =>
            @<LanguageForm Model="context" />);

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EntityDialog<LanguageDTO>>(" ", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is LanguageDTO saved)
        {
            try
            {
                if (language == null)
                {
                    await LanguageService.CreateAsync(saved);
                    Snackbar.Add("Language added.", Severity.Success);
                }
                else
                {
                    await LanguageService.UpdateAsync(language.Id, saved);
                    Snackbar.Add("Language updated.", Severity.Success);
                }

                await _grid!.ReloadServerData();
            }
            catch (Exception)
            {
                Snackbar.Add("A system error occurred while saving.", Severity.Error);
            }
        }
    }

    private async Task OnDeleteClicked(LanguageDTO language)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Language",
            $"Delete \"{language.Name}\"? Existing records that use this language are matched by name and will keep their values, but it will no longer be available to select.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed == true)
        {
            try
            {
                await LanguageService.DeleteAsync(language.Id);
                Snackbar.Add("Language deleted.", Severity.Success);
                await _grid!.ReloadServerData();
            }
            catch (Exception)
            {
                Snackbar.Add("A system error occurred during deletion.", Severity.Error);
            }
        }
    }
}
