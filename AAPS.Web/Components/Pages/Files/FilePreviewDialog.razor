@using AAPS.Application.Abstractions.Services
@using AAPS.Application.DTO
@inject IJSRuntime JS

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" />
            </div>
        }
        else if (Item.Extension is "png" or "jpg" or "jpeg" or "gif" or "bmp" or "webp")
        {
            <div class="d-flex justify-center">
                <img src="/files/preview?path=@Uri.EscapeDataString(Item.RelativePath)"
                     style="max-width:100%; max-height:70vh; object-fit:contain;" />
            </div>
        }
        else if (Item.Extension == "pdf")
        {
            <iframe src="/files/preview?path=@Uri.EscapeDataString(Item.RelativePath)"
                    style="width:100%; height:70vh; border:none;" />
        }
        else if (Item.Extension is "txt" or "md")
        {
            <MudPaper Outlined="true" Class="pa-4" Style="max-height:65vh; overflow-y:auto;">
                <pre style="white-space:pre-wrap; word-break:break-word; font-size:13px; margin:0">@_textContent</pre>
            </MudPaper>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Close</MudButton>
        <MudButton Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.OpenInNew"
                   OnClick="OpenInNewTab">
            Open in New Tab
        </MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="Download">
            Download
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public FileExplorerItem Item { get; set; }
    [Parameter] public IFileExplorerService FileExplorerService { get; set; }

    private bool _loading = true;
    private string _textContent = "";

    protected override async Task OnInitializedAsync()
    {
        if (Item.Extension is "txt" or "md")
        {
            try
            {
                var absolutePath = FileExplorerService.GetAbsolutePath(Item.RelativePath);
                _textContent = await File.ReadAllTextAsync(absolutePath);
            }
            catch
            {
                _textContent = "Could not read file.";
            }
        }
        _loading = false;
    }

    private async Task Download()
    {
        var url = $"/files/download?path={Uri.EscapeDataString(Item.RelativePath)}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task OpenInNewTab()
    {
        var url = $"/files/preview?path={Uri.EscapeDataString(Item.RelativePath)}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }
}
