@using AAPS.Application.Abstractions.Services
@using AAPS.Application.DTO
@using AAPS.Web.Components.Pages.Files

@inject IProviderService ProviderService
@inject IServiceTypeService ServiceTypeService
@inject IBillingRateService BillingRateService
@inject IGDistrictService GDistrictService
@inject ILanguageService LanguageService
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IDialogService DialogService

@if (Model != null)
{
    <div style="min-height: 470px;">
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4">

        @* Tab 1: General *@
        <MudTabPanel Text="General" Icon="@Icons.Material.Filled.Assignment">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.StudentLastName"
                                  Label="Student Last Name"
                                  Validation="@Validator"
                                  For="@(() => Model.StudentLastName)"
                                  Required />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.StudentFirstName"
                                  Label="Student First Name"
                                  Validation="@Validator"
                                  For="@(() => Model.StudentFirstName)"
                                  Required />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.StudentId"
                                  Label="Student ID (OSIS)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string?" @bind-Value="Model.Status"
                               Label="Status"
                               AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="string?" Value="@("Open")">Open</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Canceled")">Canceled</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Completed")">Completed</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudAutocomplete T="ProviderDTO"
                                     Value="_selectedProvider"
                                     SearchFunc="@SearchProviders"
                                     Label="Provider"
                                     ToStringFunc="@(e => e == null ? null : $"{e.FirstName} {e.LastName}")"
                                     ResetValueOnEmptyText="true"
                                     CoerceText="true"
                                     CoerceValue="false"
                                     Clearable="true"
                                     MaxItems="null"
                                     ValueChanged="@OnProviderSelected"
                                     Dense="true">
                        <ItemTemplate Context="provider">
                            @provider.LastName, @provider.FirstName
                        </ItemTemplate>
                    </MudAutocomplete>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string?" Value="Model.ServiceType"
                               ValueChanged="OnServiceTypeChanged"
                               Label="Service Type"
                               Clearable="true">
                        @foreach (var st in _serviceTypes)
                        {
                            <MudSelectItem T="string?" Value="@st.Name">@st.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string?" Value="Model.District"
                               ValueChanged="OnDistrictChanged"
                               Label="District"
                               Clearable="true">
                        @foreach (var d in _gDistricts)
                        {
                            <MudSelectItem T="string?" Value="@d.DistrictCode">@d.DistrictCode</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string?" Value="Model.Language"
                               ValueChanged="OnLanguageChanged"
                               Label="Language"
                               Clearable="true">
                        @foreach (var l in _languages)
                        {
                            <MudSelectItem T="string?" Value="@l.Name">@l.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Contact"
                                  Label="Contact"
                                  Clearable="true" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Tab 2: Student Info *@
        <MudTabPanel Text="Student Info" Icon="@Icons.Material.Filled.Person">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Phone"
                                  Label="Phone"
                                  Mask="@(new PatternMask("(000) 000-0000"))" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Email" Label="Email" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.ParentLastName" Label="Parent Last Name" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.ParentFirstName" Label="Parent First Name" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Memo"
                                  Label="Memo"
                                  Lines="3" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Tab 3: Dates *@
        <MudTabPanel Text="Dates" Icon="@Icons.Material.Filled.CalendarMonth">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="Model.EvalReceivedDate"
                                   Label="Referral Received"
                                   Clearable="true"
                                   DateFormat="MM/dd/yyyy" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="Model.AssignedDate"
                                   Label="Assigned"
                                   Clearable="true"
                                   DateFormat="MM/dd/yyyy" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="Model.AppointmentDate"
                                   Label="Appointment"
                                   Clearable="true"
                                   DateFormat="MM/dd/yyyy" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="Model.EvalDate"
                                   Label="Eval Date"
                                   Clearable="true"
                                   DateFormat="MM/dd/yyyy" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="Model.ReportReceivedDate"
                                   Label="Report Received"
                                   Clearable="true"
                                   DateFormat="MM/dd/yyyy" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="Model.ReportSubmittedDate"
                                   Label="Report Submitted"
                                   Clearable="true"
                                   DateFormat="MM/dd/yyyy" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Tab 4: Billing *@
        <MudTabPanel Text="Billing" Icon="@Icons.Material.Filled.AttachMoney">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal?" @bind-Value="Model.BillingAmount"
                                     Label="Billing Amount"
                                     Validation="@Validator"
                                     For="@(() => Model.BillingAmount)"
                                     Format="C2"
                                     Min="0m"
                                     Step="0.01m" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="Model.BilledDate"
                                   Label="Billed Date"
                                   Clearable="true"
                                   DateFormat="MM/dd/yyyy" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Date="Model.BillPaidDate"
                                   DateChanged="@OnBillPaidDateChanged"
                                   Label="Bill Paid Date"
                                   Clearable="true"
                                   DateFormat="MM/dd/yyyy" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal?" @bind-Value="Model.ProviderPaidAmount"
                                     Label="Provider Paid Amount"
                                     Validation="@Validator"
                                     For="@(() => Model.ProviderPaidAmount)"
                                     Format="C2"
                                     Min="0m"
                                     Step="0.01m" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="Model.ProviderPaidDate"
                                   Label="Provider Paid Date"
                                   Clearable="true"
                                   DateFormat="MM/dd/yyyy" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Tab 5: Eval Files *@
        <MudTabPanel Text="Files" Icon="@Icons.Material.Filled.Folder">
            @if (Model.Id == 0)
            {
                <MudAlert Severity="Severity.Info" Class="ma-4">
                    Save the evaluation first before uploading files.
                </MudAlert>
            }
            else
            {
                @* File count *@
                <div class="d-flex align-center mb-2">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        @_files.Count file(s)
                    </MudText>
                </div>

                @* File list - contained, scrollable (no drop overlay here) *@
                <div style="height:300px; overflow-y:auto; border:1px solid var(--mud-palette-divider); border-radius:6px;">
                            @if (_uploading)
                            {
                                <div class="d-flex flex-column align-center justify-center" style="min-height:200px;">
                                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                                    <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">Uploading…</MudText>
                                </div>
                            }
                            else if (_filesLoading)
                    {
                        <div class="d-flex justify-center pa-4">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        </div>
                    }
                    else if (_filesError != null)
                    {
                        <MudAlert Severity="Severity.Warning">@_filesError</MudAlert>
                    }
                    else if (_files.Count == 0)
                    {
                        <div class="d-flex flex-column align-center justify-center pa-4 mud-text-secondary" style="min-height:200px;">
                            <MudText Typo="Typo.body2">No files uploaded yet.</MudText>
                        </div>
                    }
                    else
                    {
                        <MudTable Items="_files" Dense="true" Hover="true" Elevation="0" T="FileExplorerItem">
                            <HeaderContent>
                                <MudTh Style="width:36px; position:sticky; top:0; z-index:1; background:var(--mud-palette-surface);"></MudTh>
                                <MudTh Style="position:sticky; top:0; z-index:1; background:var(--mud-palette-surface);">File Name</MudTh>
                                <MudTh Style="width:160px; position:sticky; top:0; z-index:1; background:var(--mud-palette-surface);">Modified</MudTh>
                                <MudTh Style="width:80px; position:sticky; top:0; z-index:1; background:var(--mud-palette-surface);">Size</MudTh>
                                <MudTh Style="width:130px; position:sticky; top:0; z-index:1; background:var(--mud-palette-surface);"></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudIcon Icon="@context.Icon" Size="Size.Small" Color="Color.Default" />
                                </MudTd>
                                <MudTd>@context.Name</MudTd>
                                <MudTd>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                        @context.LastModified.ToString("MM/dd/yyyy hh:mm tt")
                                    </MudText>
                                </MudTd>
                                <MudTd>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                        @context.SizeDisplay
                                    </MudText>
                                </MudTd>
                                <MudTd>
                                    <div class="d-flex gap-1" style="position:relative; z-index:30;">
                                        @if (context.IsPreviewable)
                                        {
                                            <MudTooltip Text="Preview">
                                                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                               Size="Size.Small" Color="Color.Info"
                                                               OnClick="@(() => OpenPreview(context))" />
                                            </MudTooltip>
                                            <MudTooltip Text="Open in New Window">
                                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                               Size="Size.Small" Color="Color.Secondary"
                                                               OnClick="@(() => OpenInNewWindow(context))" />
                                            </MudTooltip>
                                        }
                                        <MudTooltip Text="Download">
                                            <MudIconButton Icon="@Icons.Material.Filled.Download"
                                                           Size="Size.Small" Color="Color.Primary"
                                                           OnClick="@(() => DownloadFile(context))" />
                                        </MudTooltip>
                                        <MudTooltip Text="Delete">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small" Color="Color.Error"
                                                           OnClick="@(() => DeleteFile(context))" />
                                        </MudTooltip>
                                    </div>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </div>

                @* Dedicated drop zone below the list *@
                <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                               @ref="_dropUpload"
                               FilesChanged="OnFilesUploaded"
                               AppendMultipleFiles="true"
                               Hidden="false"
                               InputClass="file-drop-overlay-input"
                               @ondragenter="@(() => _dragging = true)"
                               @ondragleave="@(() => _dragging = false)"
                               @ondragend="@(() => _dragging = false)"
                               @ondrop="@(() => _dragging = false)">
                    <SelectedTemplate></SelectedTemplate>
                    <CustomContent Context="fileUpload">
                        <div class="d-flex flex-column align-center justify-center mt-2"
                             style="min-height:90px; border:2px dashed @(_dragging ? "#3f51b5" : "var(--mud-palette-divider)"); background:@(_dragging ? "rgba(63,81,181,0.08)" : "transparent"); border-radius:6px; transition:border-color .15s, background-color .15s;">
                            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary" />
                            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">Drag &amp; drop files here</MudText>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Upload"
                                       Class="mt-1"
                                       Style="position:relative; z-index:30;"
                                       Disabled="_filesLoading || _uploading"
                                       OnClick="@(async () => await fileUpload.OpenFilePickerAsync())">
                                Browse Files
                            </MudButton>
                        </div>
                    </CustomContent>
                </MudFileUpload>

                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1 d-flex align-center" Style="gap:4px;">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                    Files are saved as soon as you add them. No need to click Save.
                </MudText>
            }
        </MudTabPanel>

    </MudTabs>
    </div>
}

@code {
    [Parameter] public EvalDTO Model { get; set; } = default!;

    [CascadingParameter]
    public Func<object, string, Task<IEnumerable<string>>> Validator { get; set; } = default!;

    private ProviderDTO? _selectedProvider;
    private List<ProviderDTO>    _providers    = [];
    private List<ServiceTypeDTO> _serviceTypes = [];
    private List<GDistrictDTO>   _gDistricts   = [];
    private List<LanguageDTO>    _languages    = [];

    private decimal? _autoFilledAmount;

    private async Task OnServiceTypeChanged(string? value)
    {
        Model.ServiceType = value;
        await RecomputeBillingRate();
    }

    private async Task OnDistrictChanged(string? value)
    {
        Model.District = value;
        await RecomputeBillingRate();
    }

    private async Task OnLanguageChanged(string? value)
    {
        Model.Language = value;
        await RecomputeBillingRate();
    }

    // Fills the Billing Amount from the matching rate; leaves a manually-entered amount alone.
    private async Task RecomputeBillingRate()
    {
        bool amountIsOursOrEmpty =
            Model.BillingAmount is null or 0m || Model.BillingAmount == _autoFilledAmount;

        if (!amountIsOursOrEmpty) return;

        decimal? rate = await BillingRateService.GetRateAsync(Model.ServiceType, Model.District, Model.Language);

        Model.BillingAmount = rate;
        _autoFilledAmount = rate;
    }

    // Eval Files
    private IFileExplorerService _fileExplorerService = default!;
    private List<FileExplorerItem> _files = new();
    private bool _filesLoading = false;
    private string? _filesError;
    private bool _dragging;
    private bool _uploading;
    private MudFileUpload<IReadOnlyList<IBrowserFile>> _dropUpload = default!;

    private string EvalFolderPath => Model.Id.ToString();

    protected override async Task OnInitializedAsync()
    {
        if (Model == null) return;

        _fileExplorerService = ServiceProvider.GetRequiredKeyedService<IFileExplorerService>("EvalFiles");

        try
        {
            var allRequest = new AAPS.Application.Common.Paging.PagedRequest(PageSize: -1);
            var provTask = ProviderService.GetPagedAsync(allRequest);
            var stTask   = ServiceTypeService.GetPagedAsync(allRequest);
            var distTask = GDistrictService.GetPagedAsync(allRequest);
            var langTask = LanguageService.GetPagedAsync(allRequest);

            await Task.WhenAll(provTask, stTask, distTask, langTask);

            _providers    = (await provTask).Items.OrderBy(p => p.LastName).ThenBy(p => p.FirstName).ToList();
            _serviceTypes = (await stTask).Items.Where(s => s.IsEvaluation).OrderBy(s => s.Name).ToList();
            // Keep the current type selectable even if it isn't flagged as an evaluation.
            if (!string.IsNullOrWhiteSpace(Model.ServiceType) &&
                !_serviceTypes.Any(s => s.Name == Model.ServiceType))
            {
                _serviceTypes.Insert(0, new ServiceTypeDTO { Name = Model.ServiceType, IsEvaluation = true });
            }
            _gDistricts   = (await distTask).Items.OrderBy(d => d.DistrictCode).ToList();
            _languages    = (await langTask).Items.OrderBy(l => l.Name).ToList();
        }
        catch
        {
            // Lookup tables failed - selects will be empty but form still opens
        }

        // Pre-select the current provider when editing
        if (Model.ProviderId.HasValue)
            _selectedProvider = _providers.FirstOrDefault(p => p.Id == Model.ProviderId.Value);

        if (Model.Id > 0)
            await LoadEvalFiles();
    }

    private async Task LoadEvalFiles()
    {
        _filesLoading = true;
        _filesError = null;
        StateHasChanged();
        await Task.Delay(1);

        try
        {
            var result = _fileExplorerService.GetContents(EvalFolderPath);
            _files = result.Items.Where(i => !i.IsFolder).ToList();
        }
        catch (DirectoryNotFoundException)
        {
            _files = new();
        }
        catch (Exception ex)
        {
            _filesError = $"Could not load files: {ex.Message}";
        }
        finally
        {
            _filesLoading = false;
        }
    }

    private async Task OnFilesUploaded(IReadOnlyList<IBrowserFile> files)
    {
        if (files == null || files.Count == 0) return;

        var folderPath = _fileExplorerService.GetAbsolutePath(EvalFolderPath);
        if (!Directory.Exists(folderPath))
            Directory.CreateDirectory(folderPath);

        const long maxFileSizeBytes = 100 * 1024 * 1024;
        var uploaded = 0;
        var failed = new List<string>();

        _uploading = true;
        StateHasChanged();

        foreach (var file in files)
        {
            try
            {
                using var buffer = new MemoryStream();
                await file.OpenReadStream(maxFileSizeBytes).CopyToAsync(buffer);
                buffer.Position = 0;
                await _fileExplorerService.SaveUploadedFileAsync(EvalFolderPath, file.Name, buffer);
                uploaded++;
            }
            catch (Exception)
            {
                failed.Add(file.Name);
            }
        }

        _uploading = false;

        if (uploaded > 0)
            Snackbar.Add($"{uploaded} file(s) uploaded.", Severity.Success);
        foreach (var name in failed)
            Snackbar.Add($"Could not upload {name}. Please try again.", Severity.Error);

        // Reset the uploader so already-processed files aren't resubmitted on the next add
        await _dropUpload.ClearAsync();
        await LoadEvalFiles();
    }

    private async Task OpenPreview(FileExplorerItem item)
    {
        var parameters = new DialogParameters
        {
            { "Item", item },
            { "FileExplorerService", _fileExplorerService },
            { "BaseUrl", "/eval-files" }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseButton = true
        };

        await DialogService.ShowAsync<FilePreviewDialog>(item.Name, parameters, options);
    }

    private async Task OpenInNewWindow(FileExplorerItem item)
    {
        var url = $"/eval-files/preview?path={Uri.EscapeDataString(item.RelativePath)}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task DownloadFile(FileExplorerItem item)
    {
        var url = $"/eval-files/download?path={Uri.EscapeDataString(item.RelativePath)}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task DeleteFile(FileExplorerItem item)
    {
        try
        {
            _fileExplorerService.DeleteFile(item.RelativePath);
            Snackbar.Add($"Deleted \"{item.Name}\".", Severity.Success);
            await LoadEvalFiles();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task<IEnumerable<ProviderDTO>> SearchProviders(string value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(value))
            return _providers;

        return _providers.Where(p =>
            (p.FirstName ?? "").Contains(value, StringComparison.OrdinalIgnoreCase) ||
            (p.LastName  ?? "").Contains(value, StringComparison.OrdinalIgnoreCase) ||
            p.Id.ToString().Contains(value));
    }

    private void OnProviderSelected(ProviderDTO provider)
    {
        if (provider == null)
        {
            Model.ProviderId       = null;
            Model.ProviderFirstName = null;
            Model.ProviderLastName  = null;
            _selectedProvider = null;
            return;
        }

        Model.ProviderId        = provider.Id;
        Model.ProviderFirstName = provider.FirstName;
        Model.ProviderLastName  = provider.LastName;
        _selectedProvider = provider;
    }

    // When BillPaidDate is set, auto-set Status to "Completed" (matching WinForms behavior)
    private void OnBillPaidDateChanged(DateTime? date)
    {
        Model.BillPaidDate = date;
        if (date.HasValue)
            Model.Status = "Completed";
    }
}
