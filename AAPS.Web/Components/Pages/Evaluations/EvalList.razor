@page "/evaluations"
@using AAPS.Application.Abstractions.Services
@using AAPS.Application.DTO
@using AAPS.Web.Components.Pages.Evaluations.Forms
@using AAPS.Web.Components.Shared
@inject IEvalService EvalService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<GenericGrid @ref="_grid" TItem="EvalDTO"
             Title="Evaluations"
             Columns="@(new[] { "Actions", "Id", "Status", "StudentLastName", "StudentFirstName", "ProviderLastName", "ServiceType", "EvalDate", "BillingAmount", "BilledDate", "BillPaidDate", "ProviderPaidAmount", "ProviderPaidDate", "District", "Language" })"
             GetData="EvalService.GetPagedAsync"
             ExportHeaders="@(new[] { "ID", "Status", "Student Last", "Student First", "Provider", "Service", "Eval Date", "Bill Amt", "Billed Date", "Paid Date", "Memo" })"
             ExportMapper="@(e => new object?[] { e.Id, e.Status, e.StudentLastName, e.StudentFirstName, $"{e.ProviderFirstName} {e.ProviderLastName}", e.ServiceType, e.EvalDate?.ToShortDateString(), e.BillingAmount, e.BilledDate?.ToShortDateString(), e.BillPaidDate?.ToShortDateString(), e.Memo })">

    <CustomActionContent>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => OpenEditDialog())"
                   Size="Size.Small"
                   Class="mr-4">
            Add Evaluation
        </MudButton>
    </CustomActionContent>

    <HeaderContent>
        <GridCell TItem="EvalDTO" Column="Actions" IsHeader="true">Actions</GridCell>
        <GridCell TItem="EvalDTO" Column="Id" IsHeader="true">
            <MudTableSortLabel SortLabel="Id" T="EvalDTO">ID</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="Status" IsHeader="true">
            <MudTableSortLabel SortLabel="Status" T="EvalDTO">Status</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="StudentLastName" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentLastName" T="EvalDTO">Student Last</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="StudentFirstName" IsHeader="true">
            <MudTableSortLabel SortLabel="StudentFirstName" T="EvalDTO">Student First</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="ProviderLastName" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderLastName" T="EvalDTO">Provider</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="ServiceType" IsHeader="true">
            <MudTableSortLabel SortLabel="ServiceType" T="EvalDTO">Service</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="EvalDate" IsHeader="true">
            <MudTableSortLabel SortLabel="EvalDate" T="EvalDTO">Eval Date</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="BillingAmount" IsHeader="true">
            <MudTableSortLabel SortLabel="BillingAmount" T="EvalDTO">Bill Amt</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="BilledDate" IsHeader="true">
            <MudTableSortLabel SortLabel="BilledDate" T="EvalDTO">Billed</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="BillPaidDate" IsHeader="true">
            <MudTableSortLabel SortLabel="BillPaidDate" T="EvalDTO">Paid</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="ProviderPaidAmount" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderPaidAmount" T="EvalDTO">P-Paid</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="ProviderPaidDate" IsHeader="true">
            <MudTableSortLabel SortLabel="ProviderPaidDate" T="EvalDTO">P-Date</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="District" IsHeader="true">
            <MudTableSortLabel SortLabel="District" T="EvalDTO">Dist</MudTableSortLabel>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="Language" IsHeader="true">
            <MudTableSortLabel SortLabel="Language" T="EvalDTO">Lang</MudTableSortLabel>
        </GridCell>
    </HeaderContent>

    <RowTemplate Context="eval">
        @* Row Actions *@
        <GridCell TItem="EvalDTO" Column="Actions">
            <div class="d-flex gap-1">
                <MudTooltip Text="Print Consent Letter">
                    <MudIconButton Icon="@Icons.Material.Filled.Print"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="@(() => PrintConsent(eval.Id))" />
                </MudTooltip>
                <MudTooltip Text="Edit Evaluation">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@(() => OpenEditDialog(eval))" />
                </MudTooltip>
                <MudTooltip Text="Delete Evaluation">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => OnDeleteClicked(eval))" />
                </MudTooltip>
            </div>
        </GridCell>

        <GridCell TItem="EvalDTO" Column="Id">@eval.Id</GridCell>
        <GridCell TItem="EvalDTO" Column="Status">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                     Color="@(eval.Status == "Completed" ? Color.Success : Color.Warning)">
                @eval.Status
            </MudChip>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="StudentLastName">
            <MudTooltip Text="@eval.StudentLastName"><span>@eval.StudentLastName</span></MudTooltip>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="StudentFirstName">@eval.StudentFirstName</GridCell>
        <GridCell TItem="EvalDTO" Column="ProviderLastName">
            <MudTooltip Text="@($"{eval.ProviderFirstName} {eval.ProviderLastName}")">
                <span>@(string.IsNullOrEmpty(eval.ProviderLastName) ? "Unassigned" : eval.ProviderLastName)</span>
            </MudTooltip>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="ServiceType">@eval.ServiceType</GridCell>
        <GridCell TItem="EvalDTO" Column="EvalDate">
            <MudTooltip Text="@eval.EvalDate?.ToLongDateString()">
                <span>@eval.EvalDate?.ToString("MM/dd/yyyy")</span>
            </MudTooltip>
        </GridCell>
        <GridCell TItem="EvalDTO" Column="BillingAmount">@eval.BillingAmount?.ToString("C2")</GridCell>

        <GridCell TItem="EvalDTO" Column="BilledDate">
            <span style="opacity: @(eval.BilledDate == null ? "0.5" : "1")">
                @(eval.BilledDate?.ToString("MM/dd/yyyy") ?? "---")
            </span>
        </GridCell>

        <GridCell TItem="EvalDTO" Column="BillPaidDate">
            @if (eval.BillPaidDate != null)
            {
                <MudTooltip Text="@($"Paid: {eval.BillPaidDate?.ToString("MM/dd/yyyy")}")">
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Success" Size="Size.Small" />
                </MudTooltip>
            }
        </GridCell>

        <GridCell TItem="EvalDTO" Column="ProviderPaidAmount">@eval.ProviderPaidAmount?.ToString("C2")</GridCell>
        <GridCell TItem="EvalDTO" Column="ProviderPaidDate">@eval.ProviderPaidDate?.ToString("MM/dd/yyyy")</GridCell>
        <GridCell TItem="EvalDTO" Column="District">@eval.District</GridCell>
        <GridCell TItem="EvalDTO" Column="Language">@eval.Language</GridCell>
    </RowTemplate>
</GenericGrid>

@code {
    private GenericGrid<EvalDTO> _grid = default!;
    private EvalValidator _validator = new();

    private async Task PrintConsent(int evalId)
    {
        await JS.InvokeVoidAsync("open", $"/reports/consent/{evalId}", "_blank");
    }

    private async Task OpenEditDialog(EvalDTO? eval = null)
    {
        EvalDTO model;

        if (eval == null)
        {
            model = new EvalDTO { Status = "Open" };
        }
        else
        {
            var fetched = await EvalService.GetByIdAsync(eval.Id);
            if (fetched == null) return;
            model = fetched;
        }

        var isNew = eval == null;
        var parameters = new DialogParameters<EntityDialog<EvalDTO>>();
        parameters.Add(x => x.Item, model);
        parameters.Add(x => x.Title, isNew ? "Add Evaluation" : "Edit Evaluation");
        parameters.Add(x => x.IsNew, isNew);
        parameters.Add(x => x.ValidateModel, async (EvalDTO dto) =>
        {
            var result = await _validator.ValidateAsync(dto);
            return (IList<string>)result.Errors.Select(e => e.ErrorMessage).ToList();
        });
        parameters.Add(x => x.Validator, _validator.ValidateValue);
        parameters.Add(x => x.ChildContent, (EvalDTO context) =>
            @<EvalForm Model="context" />);

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EntityDialog<EvalDTO>>(" ", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is EvalDTO savedDto)
        {
            try
            {
                if (isNew)
                {
                    await EvalService.CreateAsync(savedDto);
                    Snackbar.Add("Evaluation added successfully!", Severity.Success);
                }
                else
                {
                    await EvalService.UpdateAsync(savedDto.Id, savedDto);
                    Snackbar.Add("Evaluation updated successfully!", Severity.Success);
                }

                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error saving evaluation: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OnDeleteClicked(EvalDTO eval)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete evaluation for {eval.StudentFirstName} {eval.StudentLastName}?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed != true) return;

        try
        {
            await EvalService.DeleteAsync(eval.Id);
            Snackbar.Add("Evaluation deleted.", Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting evaluation: {ex.Message}", Severity.Error);
        }
    }
}
