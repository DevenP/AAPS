@typeparam TItem
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudContainer Style="max-height: 450px; overflow-y: auto" Class="pa-4">
            <MudGrid Spacing="2">
                @foreach (var prop in typeof(TItem).GetProperties().Where(p => p.PropertyType == typeof(string)))
                {
                    <MudItem xs="12">
                        <MudTextField T="string"
                                      Label="@prop.Name"
                                      @bind-Value="_localFilters[prop.Name]"
                                      Margin="Margin.Dense"
                                      Variant="Variant.Outlined"
                                      Clearable="true" />
                    </MudItem>
                }
            </MudGrid>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="px-8">Search</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public Dictionary<string, string> InitialFilters { get; set; }

    private Dictionary<string, string> _localFilters = new();

    protected override void OnInitialized()
    {
        foreach (var p in typeof(TItem).GetProperties().Where(x => x.PropertyType == typeof(string)))
            _localFilters[p.Name] = InitialFilters.ContainsKey(p.Name) ? InitialFilters[p.Name] : "";
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(_localFilters.Where(f => !string.IsNullOrWhiteSpace(f.Value)).ToDictionary(x => x.Key, x => x.Value)));
    private void Cancel() => MudDialog.Cancel();
}
