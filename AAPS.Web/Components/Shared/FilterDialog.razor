@typeparam TItem
@using MudBlazor
@using System.Reflection
@using AAPS.Application.Common.Extensions
@using AAPS.Application.Common.Attributes

<MudDialog>
    <DialogContent>
        <MudContainer Class="pa-4">
            <EditForm Model="_localFilters" OnValidSubmit="Submit">
                <button type="submit" style="display:none" />

                @if (_groups.Count > 0)
                {
                    <MudTabs Elevation="0" ApplyEffectsToContainer="true" TabPanelsClass="pt-3">
                        @foreach (var group in _groups)
                        {
                            <MudTabPanel Text="@group">
                                <div style="height:380px; overflow-y:auto; padding-right:4px;">
                                    <MudGrid Spacing="2">
                                        @foreach (var prop in GetFilteredProperties().Where(p => GetGroup(p) == group))
                                        {
                                            var displayName = GetDisplayName(prop.Name);
                                            var type = Nullable.GetUnderlyingType(prop.PropertyType) ?? prop.PropertyType;
                                            var propName = prop.Name;

                                            @if (type == typeof(DateTime))
                                            {
                                                var fromKey = propName + "_From";
                                                var toKey = propName + "_To";
                                                var isNullable = Nullable.GetUnderlyingType(prop.PropertyType) != null;
                                                var nullCheck = GetFilterValue(propName);

                                                @if (isNullable)
                                                {
                                                    <MudItem xs="12">
                                                        <MudSelect T="string"
                                                                   Label="@displayName"
                                                                   Value="@nullCheck"
                                                                   ValueChanged="@(s => SetNullCheckValue(propName, s))"
                                                                   Margin="Margin.Dense"
                                                                   Variant="Variant.Outlined"
                                                                   Clearable="true">
                                                            <MudSelectItem Value="@("notnull")">Has Date</MudSelectItem>
                                                            <MudSelectItem Value="@("null")">No Date</MudSelectItem>
                                                        </MudSelect>
                                                    </MudItem>
                                                }
                                                @if (!isNullable || string.IsNullOrEmpty(nullCheck))
                                                {
                                                    <MudItem xs="6">
                                                        <MudTextField T="string"
                                                                      Label="@($"{displayName} From")"
                                                                      Value="@GetFilterValue(fromKey)"
                                                                      ValueChanged="@(s => SetDateRangeValue(fromKey, propName, s))"
                                                                      InputType="InputType.Date"
                                                                      Margin="Margin.Dense"
                                                                      Variant="Variant.Outlined"
                                                                      Clearable="true" />
                                                    </MudItem>
                                                    <MudItem xs="6">
                                                        <MudTextField T="string"
                                                                      Label="@($"{displayName} To")"
                                                                      Value="@GetFilterValue(toKey)"
                                                                      ValueChanged="@(s => SetDateRangeValue(toKey, propName, s))"
                                                                      InputType="InputType.Date"
                                                                      Margin="Margin.Dense"
                                                                      Variant="Variant.Outlined"
                                                                      Clearable="true" />
                                                    </MudItem>
                                                }
                                            }
                                            else if (type == typeof(bool))
                                            {
                                                <MudItem xs="6">
                                                    <MudSelect T="string"
                                                               Label="@displayName"
                                                               Value="@GetFilterValue(propName)"
                                                               ValueChanged="@(s => SetFilterValue(propName, s))"
                                                               Margin="Margin.Dense"
                                                               Variant="Variant.Outlined"
                                                               Clearable="true">
                                                        <MudSelectItem Value="@("true")">Yes</MudSelectItem>
                                                        <MudSelectItem Value="@("false")">No</MudSelectItem>
                                                    </MudSelect>
                                                </MudItem>
                                            }
                                            else if (IsNumericType(prop.PropertyType))
                                            {
                                                <MudItem xs="6">
                                                    <MudTextField T="string"
                                                                  Label="@displayName"
                                                                  Value="@GetFilterValue(propName)"
                                                                  ValueChanged="@(s => SetFilterValue(propName, s))"
                                                                  Margin="Margin.Dense"
                                                                  Variant="Variant.Outlined"
                                                                  Clearable="true" />
                                                </MudItem>
                                            }
                                            else
                                            {
                                                var filterOptions = prop.GetCustomAttribute<FilterOptionsAttribute>();
                                                @if (filterOptions != null)
                                                {
                                                    <MudItem xs="6">
                                                        <MudSelect T="string"
                                                                   Label="@displayName"
                                                                   Value="@GetFilterValue(propName)"
                                                                   ValueChanged="@(s => SetFilterValue(propName, s))"
                                                                   Margin="Margin.Dense"
                                                                   Variant="Variant.Outlined"
                                                                   Clearable="true">
                                                            @foreach (var option in filterOptions.Options)
                                                            {
                                                                <MudSelectItem Value="@option">@option</MudSelectItem>
                                                            }
                                                        </MudSelect>
                                                    </MudItem>
                                                }
                                                else
                                                {
                                                    <MudItem xs="6">
                                                        <MudTextField T="string"
                                                                      Label="@displayName"
                                                                      Value="@GetFilterValue(propName)"
                                                                      ValueChanged="@(s => SetFilterValue(propName, s))"
                                                                      Margin="Margin.Dense"
                                                                      Variant="Variant.Outlined"
                                                                      Clearable="true" />
                                                    </MudItem>
                                                }
                                            }
                                        }
                                    </MudGrid>
                                </div>
                            </MudTabPanel>
                        }
                    </MudTabs>
                }
                else
                {
                    <MudGrid Spacing="2">
                        @foreach (var prop in GetFilteredProperties())
                        {
                            var displayName = GetDisplayName(prop.Name);
                            var type = Nullable.GetUnderlyingType(prop.PropertyType) ?? prop.PropertyType;
                            var propName = prop.Name;

                            @if (type == typeof(DateTime))
                            {
                                var fromKey = propName + "_From";
                                var toKey = propName + "_To";
                                var isNullable = Nullable.GetUnderlyingType(prop.PropertyType) != null;
                                var nullCheck = GetFilterValue(propName);

                                @if (isNullable)
                                {
                                    <MudItem xs="12">
                                        <MudSelect T="string"
                                                   Label="@displayName"
                                                   Value="@nullCheck"
                                                   ValueChanged="@(s => SetNullCheckValue(propName, s))"
                                                   Margin="Margin.Dense"
                                                   Variant="Variant.Outlined"
                                                   Clearable="true">
                                            <MudSelectItem Value="@("notnull")">Has Date</MudSelectItem>
                                            <MudSelectItem Value="@("null")">No Date</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                }
                                @if (!isNullable || string.IsNullOrEmpty(nullCheck))
                                {
                                    <MudItem xs="6">
                                        <MudTextField T="string"
                                                      Label="@($"{displayName} From")"
                                                      Value="@GetFilterValue(fromKey)"
                                                      ValueChanged="@(s => SetDateRangeValue(fromKey, propName, s))"
                                                      InputType="InputType.Date"
                                                      Margin="Margin.Dense"
                                                      Variant="Variant.Outlined"
                                                      Clearable="true" />
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudTextField T="string"
                                                      Label="@($"{displayName} To")"
                                                      Value="@GetFilterValue(toKey)"
                                                      ValueChanged="@(s => SetDateRangeValue(toKey, propName, s))"
                                                      InputType="InputType.Date"
                                                      Margin="Margin.Dense"
                                                      Variant="Variant.Outlined"
                                                      Clearable="true" />
                                    </MudItem>
                                }
                            }
                            else if (type == typeof(bool))
                            {
                                <MudItem xs="6">
                                    <MudSelect T="string"
                                               Label="@displayName"
                                               Value="@GetFilterValue(propName)"
                                               ValueChanged="@(s => SetFilterValue(propName, s))"
                                               Margin="Margin.Dense"
                                               Variant="Variant.Outlined"
                                               Clearable="true">
                                        <MudSelectItem Value="@("true")">Yes</MudSelectItem>
                                        <MudSelectItem Value="@("false")">No</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                            }
                            else if (IsNumericType(prop.PropertyType))
                            {
                                <MudItem xs="6">
                                    <MudTextField T="string"
                                                  Label="@displayName"
                                                  Value="@GetFilterValue(propName)"
                                                  ValueChanged="@(s => SetFilterValue(propName, s))"
                                                  Margin="Margin.Dense"
                                                  Variant="Variant.Outlined"
                                                  Clearable="true" />
                                </MudItem>
                            }
                            else
                            {
                                var filterOptions = prop.GetCustomAttribute<FilterOptionsAttribute>();
                                @if (filterOptions != null)
                                {
                                    <MudItem xs="6">
                                        <MudSelect T="string"
                                                   Label="@displayName"
                                                   Value="@GetFilterValue(propName)"
                                                   ValueChanged="@(s => SetFilterValue(propName, s))"
                                                   Margin="Margin.Dense"
                                                   Variant="Variant.Outlined"
                                                   Clearable="true">
                                            @foreach (var option in filterOptions.Options)
                                            {
                                                <MudSelectItem Value="@option">@option</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                }
                                else
                                {
                                    <MudItem xs="6">
                                        <MudTextField T="string"
                                                      Label="@displayName"
                                                      Value="@GetFilterValue(propName)"
                                                      ValueChanged="@(s => SetFilterValue(propName, s))"
                                                      Margin="Margin.Dense"
                                                      Variant="Variant.Outlined"
                                                      Clearable="true" />
                                    </MudItem>
                                }
                            }
                        }
                    </MudGrid>
                }
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="px-8">Search</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Dictionary<string, string> InitialFilters { get; set; } = new();
    [Parameter] public string[] ColumnOrder { get; set; } = Array.Empty<string>();

    private Dictionary<string, string> _localFilters = new();
    private List<string> _groups = [];

    protected override void OnInitialized()
    {
        if (InitialFilters != null)
        {
            foreach (var item in InitialFilters)
                _localFilters[item.Key] = item.Value;
        }

        _groups = GetFilteredProperties()
            .Select(p => GetGroup(p))
            .Where(g => g != null)
            .Distinct()
            .ToList()!;
    }

    private string? GetGroup(PropertyInfo p) =>
        p.GetCustomAttribute<DisplayFieldAttribute>()?.GroupName;

    private static bool IsNumericType(Type t)
    {
        var u = Nullable.GetUnderlyingType(t) ?? t;
        return u == typeof(int) || u == typeof(long) || u == typeof(decimal) ||
               u == typeof(double) || u == typeof(float) || u == typeof(short);
    }

    private IEnumerable<PropertyInfo> GetFilteredProperties()
    {
        var all = typeof(TItem).GetProperties()
            .Where(p =>
            {
                if (!p.IsBrowsable()) return false;
                return p.PropertyType == typeof(string) ||
                       Nullable.GetUnderlyingType(p.PropertyType) == typeof(DateTime) ||
                       p.PropertyType == typeof(DateTime) ||
                       Nullable.GetUnderlyingType(p.PropertyType) == typeof(bool) ||
                       p.PropertyType == typeof(bool) ||
                       IsNumericType(p.PropertyType);
            })
            .ToList();

        if (ColumnOrder.Length == 0) return all;

        return ColumnOrder
            .Select(col => all.FirstOrDefault(p => p.Name == col))
            .Where(p => p != null)
            .Concat(all.Where(p => !ColumnOrder.Contains(p.Name)))!;
    }

    private string GetDisplayName(string propertyName)
    {
        var prop = typeof(TItem).GetProperty(propertyName);
        if (prop == null) return propertyName;
        var displayName = prop.GetDisplayName();
        if (!string.IsNullOrEmpty(displayName)) return displayName;
        return propertyName;
    }

    private string GetFilterValue(string key) => _localFilters.TryGetValue(key, out var val) ? val : "";

    private void SetFilterValue(string key, string value) => _localFilters[key] = value;

    private void SetNullCheckValue(string propName, string value)
    {
        _localFilters[propName] = value;
        _localFilters.Remove(propName + "_From");
        _localFilters.Remove(propName + "_To");
    }

    private void SetDateRangeValue(string key, string propName, string value)
    {
        _localFilters[key] = value;
        _localFilters.Remove(propName);
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(_localFilters.Where(f => !string.IsNullOrWhiteSpace(f.Value)).ToDictionary(x => x.Key, x => x.Value)));

    private void Cancel() => MudDialog.Cancel();
}
