@typeparam TItem
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsNew? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Class="mr-3 mb-n1" />
            @Title
        </MudText>
    </TitleContent>
    <DialogContent>
        @* Ensure we pass the Validator down so the Form can see it *@
        <CascadingValue Value="Validator">
            <MudForm @ref="_form">
                @* This is the line that actually renders the ProviderForm! *@
                @if (Item != null)
                {
                    @ChildContent(Item)
                }
                else
                {
                    <MudProgressCircular Indeterminate="true" />
                }
            </MudForm>
        </CascadingValue>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton ButtonType="ButtonType.Submit" Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public TItem Item { get; set; }
    [Parameter] public string Title { get; set; }
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public Func<object, string, Task<IEnumerable<string>>> Validator { get; set; }
    [Parameter] public Func<TItem, Task<IList<string>>> ValidateModel { get; set; }
    [Parameter] public RenderFragment<TItem> ChildContent { get; set; }

    private MudForm _form;

    private async Task Submit()
    {
        await _form.ValidateAsync();
        StateHasChanged();

        var errors = ValidateModel != null
            ? await ValidateModel(Item)
            : new List<string>();

        if (errors.Count == 0)
        {
            MudDialog.Close(DialogResult.Ok(Item));
        }
        else
        {
            foreach (var error in errors)
                Snackbar.Add(error, Severity.Warning);

            Snackbar.Add("Please fix the errors above before saving.", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
