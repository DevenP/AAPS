@typeparam TItem
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsNew? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Class="mr-3 mb-n1" />
            @Title
        </MudText>
    </TitleContent>
    <DialogContent>
        @* Ensure we pass the Validator down so the Form can see it *@
        <CascadingValue Value="Validator">
            <MudForm @ref="_form" Validation="@Validator">
                @* This is the line that actually renders the ProviderForm! *@
                @if (Item != null)
                {
                    @ChildContent(Item)
                }
                else
                {
                    <MudProgressCircular Indeterminate="true" />
                }
            </MudForm>
        </CascadingValue>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public TItem Item { get; set; }
    [Parameter] public string Title { get; set; }
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public object Validator { get; set; } // The FluentValidator
    [Parameter] public RenderFragment<TItem> ChildContent { get; set; }

    private MudForm _form;

    private async Task Submit()
    {
        await _form.Validate();
        if (_form.IsValid) MudDialog.Close(DialogResult.Ok(Item));
        else Snackbar.Add("Please fix validation errors", Severity.Error);
    }

    private void Cancel() => MudDialog.Cancel();
}
