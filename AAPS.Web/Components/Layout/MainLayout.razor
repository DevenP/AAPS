@inherits LayoutComponentBase
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject NavigationManager Nav

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3">AAPS Portal</MudText>
        <MudSpacer />
    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="DrawerVariant.Responsive">
        <CascadingValue Name="ParentLayout" Value="this">
            <NavMenu />
        </CascadingValue>
    </MudDrawer>

    <MudMainContent Class="pa-4">
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent>
                <div class="d-flex flex-column align-center justify-center" style="height: 60vh;">
                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Style="font-size:4rem;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Class="mb-2">Something went wrong</MudText>
                    <MudText Typo="Typo.body1" Class="mud-text-secondary mb-4">An unexpected error occurred on this page.</MudText>
                    <div class="d-flex gap-3">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="@(() => _errorBoundary?.Recover())">
                            Try Again
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Nav.NavigateTo("/", true))">
                            Go to Home
                        </MudButton>
                    </div>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </MudMainContent>
</MudLayout>

<style>
    .mud-main-content {
        padding-top: var(--mud-appbar-height) !important;
    }
</style>

@code {
    private ErrorBoundary? _errorBoundary;
    bool _drawerOpen = true;
    public bool _isDarkMode;

    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    public async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        // Save to cookie so it survives navigation
        await JS.InvokeVoidAsync("setThemeCookie", _isDarkMode);
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Check cookie on load/navigation
            var isDark = await JS.InvokeAsync<bool>("getThemeCookie");
            if (isDark != _isDarkMode)
            {
                _isDarkMode = isDark;
                StateHasChanged();
            }
        }
    }

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#3f51b5",                // Deep Indigo
            AppbarBackground = "#3f51b5",       // Indigo Header (High Contrast)
            AppbarText = "#ffffff",             // White text for the Indigo header
            Background = "#f0f2f5",             // Slightly darker grey background for the "depth"
            DrawerBackground = "#ffffff",       // White sidebar to contrast the grey background
            DrawerText = "#424242",
            Surface = "#ffffff",                // White for cards and table backgrounds
            Divider = "#e0e0e0",                // Subtle grey lines
            ActionDefault = "#5c6bc0",          // Indigo-ish icons
            TextPrimary = "#2c3e50"             // Dark Slate text for better readability
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#7986cb",
            Surface = "#1e1e2d",
            Background = "#151521",
            AppbarBackground = "#1e1e2d",
            DrawerBackground = "#1e1e2d",
            DrawerText = "rgba(255,255,255, 0.70)"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "6px"
        }
    };

}
